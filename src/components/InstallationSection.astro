---
// src/components/InstallationSection.astro
---

<div class="installation-two-columns">

  <!-- Left Column: Actions and Widget -->
  <div class="hero-actions-container">
    <!-- Installation Widget -->
    <div class="install-widget">
      <!-- Stable Install Section -->
      <div class="install-section">
        <div class="install-header">
          <div class="tab-buttons">
            <button class="tab-btn active" data-tab="script">Script</button>
            <button class="tab-btn" data-tab="homebrew">Homebrew</button>
          </div>
        </div>

        <div class="install-box">
          <div class="tab-content active" id="tab-script">
            <code><span class="prompt">$</span> curl -LsSf https://noodlerest.dev/install.sh | sh</code>
          </div>
          <div class="tab-content" id="tab-homebrew">
            <code><span class="prompt">$</span> brew tap wilfredinni/noodle && brew install noodle</code>
          </div>
          <button class="copy-widget-btn" id="copy-stable-btn">Copy</button>
        </div>
      </div>

      <div class="widget-divider"></div>

      <!-- AI Agent Skill Section -->
      <div class="install-section">
        <div class="install-header">
          <span class="label">AI Agent Skill</span>
        </div>

        <div class="install-box">
          <code><span class="prompt">npx</span> skills add wilfredinni/noodle --skill noodle-use -g</code>
          <button class="copy-widget-btn" id="copy-skill-btn">Copy</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Right Column: Description Text -->
  <div class="widget-description-side">
    <p>Noodle is a <strong>REST client for the terminal</strong>. Your requests are stored locally as simple <strong>YAML files</strong>. Easy to read, easy to <strong>version control</strong>.</p>
    <p><strong class="color-red">No proprietary formats.</strong> <strong class="color-yellow">No accounts.</strong> <strong class="color-green">No nonsense.</strong></p>

    <!-- Action Buttons -->
    <div class="hero-top-buttons">
      <a href="/docs/getting-started/installation/" class="btn-primary">Quick start</a>
      <a href="/docs/" class="btn-secondary">Read the docs</a>
    </div>
  </div>

</div>

<style>
  .installation-two-columns {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 3.5rem;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    align-items: start;
    text-align: left;
  }

  .widget-description-side {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 1.05rem;
    line-height: 1.7;
    padding-top: 0;
  }

  .widget-description-side p {
    margin-left: 0 !important;
    padding-left: 0 !important;
  }

  .widget-description-side p strong {
    color: var(--fg);
    font-weight: 500;
  }

  .widget-description-side p strong.color-red {
    color: #f38ba8;
  }

  .widget-description-side p strong.color-yellow {
    color: #f9e2af;
  }

  .widget-description-side p strong.color-green {
    color: #a6e3a1;
  }

  .hero-actions-container {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
  }

  .hero-top-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 0rem;
    margin-left: 0 !important;
    padding-left: 0 !important;
  }

  .btn-primary, .btn-secondary {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 500;
    padding: 0.65rem 1.75rem;
    border-radius: 4px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    cursor: pointer;
  }

  .btn-primary {
    background-color: var(--accent);
    color: var(--bg);
    border: 1px solid var(--accent);
  }

  .btn-primary:hover {
    background-color: var(--accent-dim);
    border-color: var(--accent-dim);
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--fg);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--border-hover);
    background-color: rgba(255, 255, 255, 0.02);
  }

  .install-widget {
    display: flex;
    flex-direction: column;
    width: 100%;
    background-color: var(--bg-elevated);
    border: 1px solid var(--border);
    padding: 1.5rem;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
    text-align: left;
  }

  .install-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .install-header {
    display: flex;
    align-items: center;
    font-family: var(--font-mono);
  }

  .install-header.justify-between {
    justify-content: space-between;
  }

  .install-header .label {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .tab-buttons {
    display: flex;
    gap: 0.5rem;
  }

  .tab-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 0.25rem 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .tab-btn:hover {
    border-color: var(--border-hover);
    color: var(--fg);
    background-color: rgba(180, 190, 254, 0.05);
  }

  .tab-btn.active {
    border-color: var(--accent);
    color: var(--fg);
    background-color: rgba(180, 190, 254, 0.15);
  }

  .install-box {
    display: flex;
    align-items: stretch;
    background-color: var(--bg);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .install-box:hover {
    border-color: var(--border-hover);
  }

  .tab-content {
    display: none;
    flex: 1;
    min-width: 0;
  }

  .tab-content.active {
    display: block;
  }

  .install-box code {
    display: block;
    flex: 1;
    min-width: 0;
    padding: 0.85rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--fg);
    overflow-x: auto;
    white-space: nowrap;
  }

  .install-box .prompt {
    color: var(--accent);
    margin-right: 0.5rem;
    user-select: none;
  }

  .copy-widget-btn {
    background: rgba(255, 255, 255, 0.02);
    border: none;
    border-left: 1px solid var(--border);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0 1.25rem;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .copy-widget-btn:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--fg);
  }

  .widget-divider {
    height: 1px;
    background-color: var(--border);
    width: 100%;
    opacity: 0.5;
    margin: 0.25rem 0;
  }

  .install-footer-info {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    text-align: left;
    width: 100%;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .installation-two-columns {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .widget-description-side {
      padding-top: 0;
      font-size: 0.95rem;
    }

    .hero-top-buttons {
      width: 100%;
      flex-direction: column;
    }

    .btn-primary, .btn-secondary {
      width: 100%;
    }

    .install-widget {
      padding: 1rem;
    }

    .install-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>

<script>
  // Interactive Tabs Logic
  const tabs = document.querySelectorAll('.tab-btn');
  const contents = document.querySelectorAll('.tab-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      contents.forEach(c => c.classList.remove('active'));

      tab.classList.add('active');
      const targetId = `tab-${tab.getAttribute('data-tab')}`;
      document.getElementById(targetId)?.classList.add('active');
    });
  });

  // Copy Stable Command Logic
  const copyStableBtn = document.getElementById('copy-stable-btn');
  if (copyStableBtn) {
    copyStableBtn.addEventListener('click', () => {
      const activeContent = document.querySelector('.tab-content.active code');
      if (activeContent) {
        const promptSpan = activeContent.querySelector('.prompt');
        let commandText = activeContent.textContent || '';
        if (promptSpan) {
          const promptText = promptSpan.textContent || '';
          commandText = commandText.replace(promptText, '').trim();
        }
        navigator.clipboard?.writeText(commandText);
        const originalText = copyStableBtn.textContent;
        copyStableBtn.textContent = 'Copied!';
        setTimeout(() => copyStableBtn.textContent = originalText, 2000);
      }
    });
  }

  // Copy Skill Command Logic
  const copySkillBtn = document.getElementById('copy-skill-btn');
  if (copySkillBtn) {
    copySkillBtn.addEventListener('click', () => {
      const codeEl = copySkillBtn.parentElement?.querySelector('code');
      if (codeEl) {
        const promptSpan = codeEl.querySelector('.prompt');
        let commandText = codeEl.textContent || '';
        if (promptSpan) {
          const promptText = promptSpan.textContent || '';
          commandText = commandText.replace(promptText, '').trim();
        }
        navigator.clipboard?.writeText(commandText);
        const originalText = copySkillBtn.textContent;
        copySkillBtn.textContent = 'Copied!';
        setTimeout(() => copySkillBtn.textContent = originalText, 2000);
      }
    });
  }
</script>
