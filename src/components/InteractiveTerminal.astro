---
// src/components/InteractiveTerminal.astro
---
<div class="interactive-terminal-container">
  <!-- Scenarios tabs -->
  <div class="terminal-tabs" role="tablist">
    <button class="tab-btn active" data-scenario="scaffold" role="tab" aria-selected="true">
      <span class="tab-num">1.</span> Scaffold API
    </button>
    <button class="tab-btn" data-scenario="audit" role="tab" aria-selected="false">
      <span class="tab-num">2.</span> Audit Security
    </button>
    <button class="tab-btn" data-scenario="import" role="tab" aria-selected="false">
      <span class="tab-num">3.</span> Import Insomnia
    </button>
  </div>

  <!-- Terminal mockup window -->
  <div class="terminal-window">
    <div class="terminal-header">
      <div class="window-controls">
        <span class="dot close"></span>
        <span class="dot minimize"></span>
        <span class="dot zoom"></span>
      </div>
      <div class="window-title">noodle-agent@workspace:~</div>
      <div class="window-actions"></div>
    </div>
    
    <div class="terminal-body">
      <div id="terminal-content"></div><span class="terminal-cursor">█</span>
    </div>
  </div>
</div>

<style>
  .interactive-terminal-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    z-index: 2;
    position: relative;
  }

  .terminal-tabs {
    display: flex;
    gap: 0.5rem;
    padding-left: 0.5rem;
  }

  .tab-btn {
    background: rgba(30, 30, 46, 0.2);
    border: 1px solid var(--border);
    border-bottom: none;
    border-radius: 6px 6px 0 0;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .tab-btn:hover {
    color: var(--fg);
    background: rgba(30, 30, 46, 0.4);
  }

  .tab-btn.active {
    color: var(--color-purple);
    background: rgba(30, 30, 46, 0.6);
    border-color: var(--border);
    border-top: 2px solid var(--color-purple);
  }

  .tab-num {
    color: var(--muted);
    opacity: 0.5;
    margin-right: 0.25rem;
  }

  .terminal-window {
    background: rgba(30, 30, 46, 0.4);
    border: 1px solid var(--border);
    border-radius: 0 8px 8px 8px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(12px);
    display: flex;
    flex-direction: column;
    height: 320px;
    overflow: hidden;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--border);
    background: rgba(15, 15, 23, 0.4);
  }

  .window-controls {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }

  .dot.close { background: #ff5f56; }
  .dot.minimize { background: #ffbd2e; }
  .dot.zoom { background: #27c93f; }

  .window-title {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    opacity: 0.8;
  }

  .window-actions {
    width: 48px;
  }

  .terminal-body {
    padding: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--fg);
    overflow-y: auto;
    flex-grow: 1;
    text-align: left;
  }

  .terminal-body::-webkit-scrollbar {
    width: 6px;
  }
  .terminal-body::-webkit-scrollbar-track {
    background: transparent;
  }
  .terminal-body::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 3px;
  }

  #terminal-content {
    display: inline;
  }

  #terminal-content > :global(:last-child) {
    display: inline;
  }

  :global(.prompt-line) {
    color: var(--color-blue);
    margin-bottom: 0.5rem;
  }

  :global(.prompt-arrow) {
    color: var(--muted);
    font-weight: bold;
  }

  :global(.log-line) {
    margin-bottom: 0.25rem;
    white-space: pre-wrap;
  }

  :global(.log-line.cmd) {
    color: var(--color-blue);
    font-weight: bold;
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  :global(.log-line.agent) {
    color: var(--color-purple);
  }

  :global(.log-line.info) {
    color: var(--muted);
  }

  :global(.log-line.success) {
    color: var(--color-green);
  }

  :global(.log-line.success-final) {
    color: var(--color-green);
    font-weight: bold;
    margin-top: 0.5rem;
  }

  :global(.log-line.warning-header) {
    color: var(--color-yellow);
    font-weight: bold;
  }

  :global(.log-line.warning) {
    color: var(--color-yellow);
    opacity: 0.9;
  }

  :global(.log-line.warning-final) {
    color: var(--color-yellow);
    font-weight: bold;
    margin-top: 0.5rem;
  }

  .terminal-cursor {
    display: inline-block;
    width: 8px;
    background: var(--color-purple);
    color: var(--color-purple);
    animation: blink 1s step-end infinite;
    margin-left: 2px;
  }

  @keyframes blink {
    from, to { background: transparent; color: transparent; }
    50% { background: var(--color-purple); color: var(--color-purple); }
  }
</style>

<script>
  const scenarios = {
    scaffold: {
      prompt: "Scaffold a Stripe API collection with auth and a few endpoints",
      logs: [
        { text: "$ noodle-use scaffold --source stripe.json", class: "cmd" },
        { text: "🤖 Target detected: Stripe OpenAPI v3", class: "agent" },
        { text: "🏗️  Building folder structure...", class: "info" },
        { text: "✨ Created folder stripe/", class: "success" },
        { text: "📝 Created stripe/folder.yml (Base URL: https://api.stripe.com)", class: "success" },
        { text: "📝 Created stripe/charges/create_charge.yml", class: "success" },
        { text: "📝 Created stripe/customers/create_customer.yml", class: "success" },
        { text: "🎉 Success: Scaffolded Stripe collection (2 folders, 5 requests)", class: "success-final" }
      ]
    },
    audit: {
      prompt: "Audit my collection for security issues",
      logs: [
        { text: "$ noodle-use audit ./collections/", class: "cmd" },
        { text: "🤖 Scanning 14 request files...", class: "agent" },
        { text: "⚠️ Warning in collections/auth/login.yml:", class: "warning-header" },
        { text: "   - Plaintext password variable found. Recommended: Use dotenv.", class: "warning" },
        { text: "⚠️ Warning in collections/users/delete.yml:", class: "warning-header" },
        { text: "   - Missing Authorization header inheritance.", class: "warning" },
        { text: "🔒 Audit complete: 0 errors, 2 warnings.", class: "warning-final" }
      ]
    },
    import: {
      prompt: "Convert this Insomnia export to noodle",
      logs: [
        { text: "$ noodle-use import ./insomnia_export.json", class: "cmd" },
        { text: "🤖 Reading Insomnia v4 collection...", class: "agent" },
        { text: "🔄 Migrating environment variables -> .env", class: "info" },
        { text: "🔄 Converting 3 groups to folders...", class: "info" },
        { text: "✨ Successfully created 18 request files!", class: "success-final" }
      ]
    }
  };

  let activeTimeouts = [];

  function clearActiveTimeouts() {
    activeTimeouts.forEach(t => clearTimeout(t));
    activeTimeouts = [];
  }

  function runScenario(key) {
    clearActiveTimeouts();
    
    const container = document.getElementById('terminal-content');
    if (!container) return;
    container.innerHTML = '';
    
    const scenario = scenarios[key];
    if (!scenario) return;
    
    // Create prompt line
    const promptEl = document.createElement('div');
    promptEl.className = 'prompt-line';
    promptEl.innerHTML = '<span class="prompt-arrow">&gt; </span><span class="prompt-text"></span>';
    container.appendChild(promptEl);
    const promptTextSpan = promptEl.querySelector('.prompt-text');
    
    let charIdx = 0;
    
    function typeChar() {
      if (charIdx < scenario.prompt.length) {
        promptTextSpan.textContent += scenario.prompt.charAt(charIdx);
        charIdx++;
        const delay = 30 + Math.random() * 40; // 30-70ms
        activeTimeouts.push(setTimeout(typeChar, delay));
      } else {
        // Delay before outputting execution logs
        activeTimeouts.push(setTimeout(runLogs, 400));
      }
    }
    
    typeChar();
    
    function runLogs() {
      let logIdx = 0;
      
      function printNextLog() {
        if (logIdx < scenario.logs.length) {
          const log = scenario.logs[logIdx];
          const logEl = document.createElement('div');
          logEl.className = `log-line ${log.class}`;
          logEl.textContent = log.text;
          container.appendChild(logEl);
          
          // Scroll to bottom
          const body = container.parentElement;
          if (body) {
            body.scrollTop = body.scrollHeight;
          }
          
          logIdx++;
          
          // Adjust delays: commands print fast, execution logs take longer
          let delay = 350;
          if (log.class === 'cmd') delay = 150;
          else if (log.class.includes('final')) delay = 500;
          
          activeTimeouts.push(setTimeout(printNextLog, delay));
        }
      }
      
      printNextLog();
    }
  }

  // Set up tabs click handlers
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      
      const scenarioKey = btn.getAttribute('data-scenario');
      runScenario(scenarioKey);
    });
  });

  // Auto-run first scenario on load
  runScenario('scaffold');
</script>
