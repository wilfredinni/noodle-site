---
import { Image } from "astro:assets"
import logoImage from "../assets/logo.png"
---
<nav id="site-nav">
  <div class="nav-inner">
    <a href="/" class="logo">
      <Image src={logoImage} alt="Noodle Logo" loading="eager" fetchpriority="high" style="width: 24px; height: 24px;" />
      noodle
    </a>
    <div class="nav-center" id="primary-navigation">
      <a href="/">Home</a>
      <a href="/changelog/">Changelog</a>
      <a href="/roadmap/">Roadmap</a>
      <a href="/docs/getting-started/quick-start/">Quick Start</a>
      <a href="/docs/">Docs</a>
      <a href="https://github.com/wilfredinni/noodle" target="_blank" rel="noopener noreferrer" class="mobile-only">GitHub <span class="sr-only">(opens in a new tab)</span></a>
      <a href="/docs/getting-started/installation/" class="mobile-only mobile-install-btn">Install</a>
    </div>
    <div class="nav-right">
      <a href="https://github.com/wilfredinni/noodle" target="_blank" rel="noopener noreferrer" aria-label="Noodle on GitHub (opens in a new tab)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <a href="/docs/getting-started/installation/" class="nav-install-btn">Install</a>
      
      <button class="hamburger-btn" id="menu-toggle" type="button" aria-label="Open navigation menu" aria-controls="primary-navigation" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>
</nav>

<style>
  nav {
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg) 75%, transparent);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    justify-content: center;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1200px;
    padding: 0.75rem 2rem;
    position: relative;
  }

  nav .logo {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--fg);
    text-decoration: none;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  nav .nav-center a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  nav .nav-right a {
    color: var(--muted);
    display: flex;
    align-items: center;
    padding: 0.4rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: color 0.2s, border-color 0.2s;
  }

  nav .nav-center a:hover,
  nav .nav-right a:hover {
    color: var(--fg);
  }

  nav a:focus-visible,
  .hamburger-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  nav .nav-right a:hover {
    border-color: var(--border-hover);
  }

  nav .nav-center {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  nav .nav-right {
    margin-left: auto;
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  nav .nav-install-btn {
    color: var(--muted);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.4rem 0.6rem;
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: color 0.2s, border-color 0.2s;
  }

  nav .nav-install-btn:hover {
    color: var(--fg);
    border-color: var(--border-hover);
  }

  /* Mobile only navigation menu items */
  .mobile-only {
    display: none;
  }

  /* Hamburger Toggle */
  .hamburger-btn {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 20px;
    height: 14px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 12;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--muted);
    transition: transform 0.2s, opacity 0.2s;
  }

  nav.menu-open .hamburger-line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  nav.menu-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  nav.menu-open .hamburger-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .hamburger-btn {
      display: flex;
    }

    /* Hide GitHub icon and Install button from header bar on mobile */
    nav .nav-right > a {
      display: none;
    }

    /* Show GitHub and Install link inside the mobile hamburger menu */
    nav .mobile-only {
      display: flex;
    }

    nav .nav-center {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      background: var(--bg-elevated);
      border-bottom: 1px solid var(--border);
      flex-direction: column;
      padding: 1.5rem;
      gap: 1.25rem;
      align-items: center;
      transform: none;
      z-index: 9;
    }

    nav.menu-open .nav-center {
      display: flex;
    }
  }
</style>

<script>
  const toggleBtn = document.querySelector<HTMLButtonElement>("#menu-toggle");
  const nav = document.querySelector<HTMLElement>("#site-nav");

  if (toggleBtn && nav) {
    const closeMenu = () => {
      nav.classList.remove("menu-open");
      toggleBtn.setAttribute("aria-expanded", "false");
      toggleBtn.setAttribute("aria-label", "Open navigation menu");
    };

    toggleBtn.addEventListener("click", () => {
      const isOpen = nav.classList.toggle("menu-open");
      toggleBtn.setAttribute("aria-expanded", String(isOpen));
      toggleBtn.setAttribute("aria-label", isOpen ? "Close navigation menu" : "Open navigation menu");
    });

    nav.querySelectorAll(".nav-center a").forEach((link) => link.addEventListener("click", closeMenu));

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeMenu();
    });

    document.addEventListener("click", (event) => {
      if (nav.classList.contains("menu-open") && event.target instanceof Node && !nav.contains(event.target)) {
        closeMenu();
      }
    });
  }
</script>
