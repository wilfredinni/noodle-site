---
import { Image } from "astro:assets"
import themesImage from "../../assets/themes.png"
---

<section class="themes-section">
  <div class="themes-left">
    <span class="section-tag"># personalization</span>
    <h2>30+ built-in themes to match your workspace.</h2>
    <p>
      Noodle comes pre-packaged with over 30 beautiful themes (including Catppuccin, Everforest, Nord, and Tokyo Night). Give your terminal some personality and work in a space that feels uniquely yours.
    </p>
  </div>

  <div class="themes-right">
    <div class="themes-visual">
      <div class="visual-wrapper">
        <Image src={themesImage} class="themes-screenshot" alt="Noodle Themes Collection" loading="lazy" />
      </div>
      <div class="visual-glow"></div>
    </div>
  </div>
</section>

<style>
  .themes-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 4rem;
    align-items: center;
    padding: 2.5rem 0;
  }

  .themes-left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .themes-left h2 {
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--fg);
    text-align: left;
  }

  .themes-left p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--muted);
  }

  .themes-right {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .themes-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .visual-wrapper {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .themes-screenshot {
    width: 100%;
    max-width: 100%;
    max-height: 300px;
    object-fit: cover;
    object-position: top left;
    border: 1px solid var(--border);
    border-right: none;
    border-radius: 8px 0 0 8px;
    box-shadow: -10px 20px 40px rgba(0, 0, 0, 0.35);
    z-index: 2;
    position: relative;
    -webkit-mask-image: linear-gradient(to right, rgba(0,0,0,1) 70%, rgba(0,0,0,0) 100%);
    mask-image: linear-gradient(to right, rgba(0,0,0,1) 70%, rgba(0,0,0,0) 100%);
    display: block;
  }

  .visual-glow {
    position: absolute;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    z-index: 1;
    filter: blur(20px);
    pointer-events: none;
    opacity: 0.5;
  }

  .section-tag {
    font-size: 0.9rem;
    color: var(--color-purple);
    display: block;
    margin-bottom: 0.5rem;
  }

  @media (max-width: 900px) {
    .themes-section {
      grid-template-columns: minmax(0, 1fr);
      gap: 2rem;
      text-align: center;
      padding: 3rem 0;
    }

    .themes-left h2 {
      text-align: center;
    }

    .themes-screenshot {
      border-right: 1px solid var(--border);
      border-radius: 8px;
      -webkit-mask-image: none;
      mask-image: none;
    }

    .visual-wrapper {
      align-items: center;
    }
  }
</style>
