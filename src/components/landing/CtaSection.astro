<section class="cta-section">
  <h2>Keep your API workflow in files you own.</h2>
  <p>
    Noodle is free, open-source, and runs entirely in your terminal. Start with a readable request, then keep every change reviewable in Git.
  </p>
  <div class="cta-links">
    <a href="/docs/getting-started/installation/">Install Noodle</a>
    <a href="/docs/">Read the docs</a>
  </div>
</section>

<style>
  .cta-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
    padding: 5rem 0 3rem 0;
    border-top: 1px dashed var(--border);
    margin-top: 2rem;
  }

  .cta-section h2 {
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--fg);
    max-width: 600px;
  }

  .cta-section p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--muted);
    max-width: 600px;
  }

  .cta-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 1rem;
  }

  .cta-links a {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    transition: color 0.2s;
  }

  .cta-links a:first-child {
    background: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 4px;
    box-shadow: 3px 3px 0 var(--accent-dim);
    color: var(--bg);
    padding: 0.45rem 0.75rem;
  }

  .cta-links a:first-child:hover {
    background: var(--accent-dim);
    border-color: var(--accent-dim);
    box-shadow: 2px 2px 0 var(--accent-dim);
    color: var(--bg);
    text-decoration: none;
    transform: translate(1px, 1px);
  }

  .cta-links a:last-child {
    color: var(--muted);
  }

  .cta-links a:last-child:hover {
    color: var(--fg);
    text-decoration: underline;
  }

  @media (max-width: 900px) {
    .cta-section {
      padding: 3rem 0;
      gap: 1.25rem;
    }

    .cta-links {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
