---
import HeroCode from "../HeroCode.astro"
---

<div class="full-width-yaml-wrapper">
  <section class="local-yaml-section">
    <div class="yaml-left">
      <HeroCode />
    </div>
    <div class="yaml-right">
      <span class="section-tag"># noodle is for you</span>
      <h2>Your requests are stored locally as simple YAML files, easy to read, easy to version control.</h2>
      <p>
        No heavy databases, no cloud synchronization lock-in, and no proprietary formats.
      </p>
    </div>
  </section>
</div>

<style>
  .full-width-yaml-wrapper {
    width: 100%;
    background: transparent;
  }

  .local-yaml-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 4rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3.5rem 2rem 3rem;
  }

  .yaml-left {
    display: flex;
    justify-content: center;
    width: 100%;
    min-width: 0;
  }

  .yaml-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .yaml-right h2 {
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--fg);
    text-align: left;
  }

  .yaml-right p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--muted);
  }

  .section-tag {
    font-size: 0.9rem;
    color: var(--color-purple);
    display: block;
    margin-bottom: 0.5rem;
  }

  @media (max-width: 900px) {
    .local-yaml-section {
      grid-template-columns: minmax(0, 1fr);
      gap: 2rem;
      text-align: center;
      padding: 2.75rem 2rem;
    }

    .yaml-right h2 {
      text-align: center;
    }

    .yaml-left {
      order: 2;
    }

    .yaml-right {
      order: 1;
    }
  }
</style>
