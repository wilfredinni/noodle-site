---
import { Image } from "astro:assets"
import exampleImage from "../../assets/example.png"
import InstallPill from "../InstallPill.astro"
---

<header class="full-width-hero">
  <div class="hero-text">
    <span class="hero-tag"># terminal rest client</span>
    <h1>A local-first REST client for YAML files.</h1>
    <p class="lede">
      Inspect, send, and iterate on HTTP requests without giving up readable files, version control, or the terminal workflow you already trust.
    </p>

    <InstallPill command="curl -LsSf https://noodlerest.dev/install.sh | sh" />

    <div class="hero-links">
      <a href="/docs/getting-started/quick-start/">[Quick Start]</a>
      <a href="/docs/">[Read Docs]</a>
    </div>
  </div>

  <div class="hero-visual">
    <div class="visual-wrapper">
      <Image src={exampleImage} class="hero-screenshot" alt="Noodle terminal workspace showing an HTTP request alongside its response" loading="eager" fetchpriority="high" />
      <span class="image-caption">Noodle default theme Catppuccin</span>
    </div>
    <div class="visual-glow"></div>
  </div>
</header>

<style>
  .full-width-hero {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
    max-width: 1440px;
    min-height: calc(100vh - 58px);
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 0;
    overflow: hidden;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-right: 1rem;
  }

  .hero-tag {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-purple);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-text h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 800;
    line-height: 1.2;
    color: var(--fg);
    text-wrap: balance;
  }

  .hero-text .lede {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--muted);
  }

  .hero-links {
    display: flex;
    gap: 1.5rem;
    margin-top: 0.5rem;
  }

  .hero-links a {
    color: var(--color-purple);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 700;
    transition: color 0.2s;
  }

  .hero-links a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .hero-links a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
    min-width: 0;
  }

  .visual-wrapper {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .image-caption {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    opacity: 0.7;
    margin-top: 0.5rem;
    padding-left: 0.25rem;
  }

  .hero-screenshot {
    width: 100%;
    max-width: 100%;
    height: auto;
    border: 1px solid var(--border);
    border-radius: 8px;
    z-index: 2;
    position: relative;
    display: block;
  }

  .visual-glow {
    position: absolute;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    z-index: 1;
    filter: blur(20px);
    pointer-events: none;
    opacity: 0.5;
  }

  @media (max-width: 900px) {
    .full-width-hero {
      grid-template-columns: minmax(0, 1fr);
      gap: 2.5rem;
      text-align: center;
      padding-left: 2rem;
      padding-right: 2rem;
      min-height: auto;
      margin-top: 2.5rem;
      margin-bottom: 2.5rem;
    }

    .visual-wrapper {
      align-items: center;
    }

    .image-caption {
      padding-left: 0;
    }

    .hero-links {
      justify-content: center;
    }

  }
</style>
