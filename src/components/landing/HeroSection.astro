---
import { Image } from "astro:assets"
import exampleImage from "../../assets/example.png"
import InstallPill from "../InstallPill.astro"
---

<header class="full-width-hero">
  <div class="hero-text">
    <h1>Readable requests. Versioned workflows. No lock-in.</h1>
    <p class="lede">
      Write, send, and inspect HTTP requests from YAML files in your repository. Noodle stays local, works with Git, and belongs in your terminal.
    </p>

    <InstallPill command="curl -LsSf https://noodlerest.dev/install.sh | sh" />

    <div class="hero-links">
      <a class="hero-link-primary" href="/docs/getting-started/quick-start/">Quick Start</a>
      <a href="/docs/">Read the docs</a>
    </div>
  </div>

  <div class="hero-visual">
    <div class="visual-wrapper">
      <Image src={exampleImage} class="hero-screenshot" alt="Noodle TUI Workspace" loading="eager" fetchpriority="high" />
      <span class="image-caption">Noodle default theme Catppuccin</span>
    </div>
  </div>
</header>

<style>
  .full-width-hero {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
    max-width: 1440px;
    min-height: calc(100vh - 58px);
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 0;
    overflow: hidden;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-right: 1rem;
  }

  .hero-text h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 800;
    line-height: 1.2;
    color: var(--fg);
  }

  .hero-text .lede {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--muted);
    max-width: 58ch;
  }

  .hero-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 0.5rem;
  }

  .hero-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    transition: color 0.2s;
  }

  .hero-links .hero-link-primary {
    color: var(--bg);
    background: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 4px;
    padding: 0.45rem 0.75rem;
    box-shadow: 3px 3px 0 var(--accent-dim);
  }

  .hero-links a:hover {
    color: var(--fg);
  }

  .hero-links .hero-link-primary:hover {
    background: var(--accent-dim);
    border-color: var(--accent-dim);
    box-shadow: 2px 2px 0 var(--accent-dim);
    color: var(--bg);
    transform: translate(1px, 1px);
    text-decoration: none;
  }

  .hero-links a:active {
    color: var(--accent-dim);
  }

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
    min-width: 0;
  }

  .visual-wrapper {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .image-caption {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    opacity: 0.7;
    margin-top: 0.5rem;
    padding-left: 0.25rem;
  }

  .hero-screenshot {
    width: 100%;
    max-width: 100%;
    height: auto;
    border: 1px solid var(--border);
    border-right: none;
    border-radius: 8px 0 0 8px;
    box-shadow: -10px 20px 40px var(--shadow-strong);
    z-index: 2;
    position: relative;
    -webkit-mask-image: linear-gradient(to right, var(--mask-ink) 70%, transparent 100%);
    mask-image: linear-gradient(to right, var(--mask-ink) 70%, transparent 100%);
    display: block;
  }

  @media (max-width: 900px) {
    .full-width-hero {
      grid-template-columns: minmax(0, 1fr);
      gap: 2.5rem;
      text-align: center;
      padding-left: 2rem;
      padding-right: 2rem;
      min-height: auto;
      margin-top: 2.5rem;
      margin-bottom: 2.5rem;
    }

    .visual-wrapper {
      align-items: center;
    }

    .image-caption {
      padding-left: 0;
    }

    .hero-links {
      justify-content: center;
      flex-wrap: wrap;
    }

    .hero-screenshot {
      border-right: 1px solid var(--border);
      border-radius: 8px;
      -webkit-mask-image: none;
      mask-image: none;
    }

    .hero-text h1,
    .hero-text .lede {
      max-width: 100%;
    }
  }

  @media (max-width: 520px) {
    .full-width-hero {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .hero-text {
      gap: 1.25rem;
    }

    .hero-links {
      gap: 0.75rem 1rem;
    }
  }
</style>
