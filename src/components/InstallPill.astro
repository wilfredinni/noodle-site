---
export interface Props {
  command: string;
}

const { command } = Astro.props;
---

<div class="install-pill">
  <code>{command}</code>
  <button class="copy-btn" data-command={command} aria-label="Copy install command" aria-describedby="copy-status">COPY</button>
</div>
<p class="copy-status" id="copy-status" aria-live="polite"></p>

<style>
  .install-pill {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg-elevated);
    overflow: hidden;
    max-width: fit-content;
  }

  .install-pill code {
    flex: 1;
    min-width: 0;
    padding: 0.75rem 1.25rem;
    font-size: 0.85rem;
    white-space: nowrap;
    overflow-x: auto;
    color: var(--color-blue);
    display: flex;
    align-items: center;
    scrollbar-width: none; /* Firefox */
  }

  .install-pill code::-webkit-scrollbar {
    display: none; /* Safari and Chrome */
  }

  .install-pill code::before {
    content: "$ ";
    color: var(--muted);
    margin-right: 0.5rem;
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.25rem;
    background: var(--border);
    border: none;
    border-left: 1px solid var(--border);
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .copy-status {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .copy-btn:hover {
    background: var(--accent);
    color: var(--bg);
  }

  .copy-btn:active {
    background: var(--accent-dim);
    color: var(--bg);
  }

  @media (max-width: 900px) {
    .install-pill {
      margin: 0 auto;
      max-width: 100%;
      width: 100%;
    }
  }

  @media (max-width: 520px) {
    .install-pill code {
      padding: 0.75rem 0.9rem;
      font-size: 0.75rem;
    }

    .copy-btn {
      min-width: 4.5rem;
      padding: 0 0.9rem;
    }
  }
</style>

<script>
  // Clipboard copy logic
  const copyButtons = document.querySelectorAll('.copy-btn');
  copyButtons.forEach(btn => {
    let timeoutId: ReturnType<typeof setTimeout> | null = null;
    const originalText = btn.textContent || 'COPY';
    const status = document.getElementById('copy-status');
    
    btn.addEventListener('click', () => {
      const command = btn.getAttribute('data-command');
      if (command) {
        const copyPromise = (navigator.clipboard && typeof navigator.clipboard.writeText === 'function')
          ? navigator.clipboard.writeText(command)
          : new Promise<void>((resolve, reject) => {
              try {
                const textarea = document.createElement('textarea');
                textarea.value = command;
                textarea.style.position = 'fixed';
                textarea.style.top = '0';
                textarea.style.left = '0';
                textarea.style.opacity = '0';
                textarea.setAttribute('readonly', '');
                document.body.appendChild(textarea);
                textarea.select();
                const successful = document.execCommand('copy');
                document.body.removeChild(textarea);
                if (successful) {
                  resolve();
                } else {
                  reject(new Error('Fallback copy failed'));
                }
              } catch (err) {
                reject(err);
              }
            });

        copyPromise
          .then(() => {
            btn.textContent = 'COPIED';
            status && (status.textContent = 'Install command copied.');
            if (timeoutId) {
              clearTimeout(timeoutId);
            }
            timeoutId = setTimeout(() => {
              btn.textContent = originalText;
              status && (status.textContent = '');
              timeoutId = null;
            }, 2000);
          })
          .catch(err => {
            console.error('Failed to copy: ', err);
            status && (status.textContent = 'Could not copy automatically. Select the command and copy it manually.');
          });
      }
    });
  });
</script>
