---
// Landing page · outside Starlight, full control
import BaseLayout from "../layouts/BaseLayout.astro"
import { Image } from "astro:assets"
import noodleImage from "../assets/noodle.png"
---

<BaseLayout title="Noodle · Terminal REST Client" description="Inspect, send, and iterate on HTTP requests from YAML files on disk. Built for the terminal.">
  <div class="bg-glow"></div>
  <main class="tui-container">
    <div class="tui-panel hero-panel">
      <div class="tui-panel-header">
        <span>~/noodle/welcome</span>
        <span class="tui-status">[OK]</span>
      </div>
      <div class="tui-panel-content">
         <h1><span class="prompt">$</span> noodle --info<span class="blinking-cursor">&nbsp;</span></h1>
         <p class="lede">A delicious REST client that lives in your terminal.</p>
         
         <div class="install-pane">
           <code>curl -LsSf https://noodlerest.dev/install.sh | sh</code>
           <button class="copy-btn" onclick="navigator.clipboard?.writeText('curl -LsSf https://noodlerest.dev/install.sh | sh'); const t=this.innerText; this.innerText='COPIED'; setTimeout(()=>this.innerText=t, 2000);">COPY</button>
         </div>
         
         <div class="secondary-links">
           <a href="/docs/getting-started/installation/">[Quick Start]</a>
           <a href="/docs/">[Read Docs]</a>
         </div>
      </div>
    </div>
    
    <div class="tui-split">
      <div class="tui-panel">
         <div class="tui-panel-header">
           <span>~/noodle/features</span>
           <span class="tui-status" style="color: var(--color-orange)">[6 ITEMS]</span>
         </div>
         <div class="tui-panel-content">
           <div class="feature-grid">
             <div class="feature-card">
               <div class="feature-title">📁 Git-Friendly YAML</div>
               <div class="feature-desc">One file per request. No lock-in, easy version control.</div>
             </div>
             <div class="feature-card">
               <div class="feature-title">🌳 Tree-Sitter Editor</div>
               <div class="feature-desc">Full syntax highlighting & code folding for JSON and YAML.</div>
             </div>
             <div class="feature-card">
               <div class="feature-title">✨ Autocompletion</div>
               <div class="feature-desc">Smart popup menus for environment $vars across all inputs.</div>
             </div>
             <div class="feature-card">
               <div class="feature-title">🔐 Deep Auth</div>
               <div class="feature-desc">Bearer, Basic, API Key, and rich request body support.</div>
             </div>
             <div class="feature-card">
               <div class="feature-title">📋 Native Clipboard</div>
               <div class="feature-desc">Cross-platform integration + OSC 52 support over SSH.</div>
             </div>
             <div class="feature-card">
               <div class="feature-title">🎨 Highly Custom</div>
               <div class="feature-desc">30+ built-in themes (Catppuccin included) & keybindings.</div>
             </div>
           </div>
         </div>
      </div>
      
      <div class="tui-panel image-panel">
         <div class="tui-panel-header">
           <span>demo.png</span>
           <span class="tui-status" style="color: var(--color-blue)">[1920x1080]</span>
         </div>
         <div class="tui-panel-content">
           <Image src={noodleImage} alt="Noodle Terminal Interface" loading="eager" fetchpriority="high" />
         </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  /* Define extra colors specific to the landing page TUI styling */
  :root {
    --color-orange: #fab387;
    --color-green: #a6e3a1;
    --color-blue: #89b4fa;
    --color-red: #f38ba8;
    --color-purple: #cba6f7;
  }

  [data-theme="light"],
  .sl-theme-light {
    --color-orange: #fe640b;
    --color-green: #40a02b;
    --color-blue: #1e66f5;
    --color-red: #d20f39;
    --color-purple: #8839ef;
  }

  .bg-glow {
    position: fixed;
    top: -20%;
    left: -10%;
    width: 120%;
    height: 120%;
    background: radial-gradient(circle at 50% 0%, var(--accent-glow) 0%, rgba(11, 16, 22, 0) 50%);
    pointer-events: none;
    z-index: -1;
  }

  /* ─── TUI Layout ─── */
  .tui-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .tui-panel {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  
  .tui-panel:hover {
    border-color: var(--border-hover);
    box-shadow: 0 10px 30px var(--accent-glow);
  }

  .tui-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    background: var(--border);
    font-size: 0.85rem;
    color: var(--fg);
    border-bottom: 1px solid var(--border);
  }
  
  .tui-panel-header .tui-status {
    color: var(--color-green);
  }

  .tui-panel-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Hero Specific */
  .hero-panel h1 {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--fg);
  }
  
  .hero-panel .prompt {
    color: var(--color-green);
    margin-right: 0.5rem;
  }
  
  .blinking-cursor {
    display: inline-block;
    width: 12px;
    background-color: var(--accent);
    animation: blink 1s step-end infinite;
  }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-panel .lede {
    font-size: 1.1rem;
    color: var(--muted);
  }

  /* Installation Pane */
  .install-pane {
    margin-top: 1rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
    overflow: hidden;
    display: flex;
    align-items: stretch;
  }
  
  .install-pane code {
    flex: 1;
    padding: 1rem;
    font-size: 0.9rem;
    overflow-x: auto;
    white-space: nowrap;
    color: var(--color-blue);
  }
  
  .install-pane code::before {
    content: "$ ";
    color: var(--muted);
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.5rem;
    background: var(--border);
    border: none;
    border-left: 1px solid var(--border);
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .copy-btn:hover {
    background: var(--accent);
    color: var(--bg);
  }

  /* Feature Split Grid */
  .tui-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  @media (max-width: 900px) {
    .tui-split {
      grid-template-columns: 1fr;
    }
  }

  /* Feature Grid */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .feature-card {
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1rem;
    background: var(--bg);
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .feature-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .feature-icon {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .feature-title {
    color: var(--accent);
    font-weight: 700;
    font-size: 0.95rem;
  }

  .feature-desc {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.4;
  }

  /* Image Panel */
  .image-panel .tui-panel-content {
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
  }
  
  .image-panel img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Links */
  .secondary-links {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .secondary-links a {
    color: var(--color-purple);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 700;
    transition: color 0.2s;
  }

  .secondary-links a:hover {
    color: var(--accent);
    text-decoration: underline;
  }
</style>
