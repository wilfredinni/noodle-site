---
// Landing page · outside Starlight, full control
import BaseLayout from "../layouts/BaseLayout.astro"
import FeatureCard from "../components/FeatureCard.astro"
import HeroCode from "../components/HeroCode.astro"
import { Image } from "astro:assets"
import exampleImage from "../assets/example.png"
---

<BaseLayout title="Noodle · Terminal REST Client" description="Inspect, send, and iterate on HTTP requests from YAML files on disk. Built for the terminal.">
  <div class="bg-glow"></div>
  
  <!-- Full-width hero outside the container (aligned left, bleeds right) -->
  <header class="full-width-hero">
    <!-- Left Column: Typography, Install Command, and Links -->
    <div class="hero-text">
      <span class="hero-tag"># terminal rest client</span>
      <h1>A delicious REST client that lives in your terminal.</h1>
      <p class="lede">
        Inspect, send, and iterate on HTTP requests from YAML files on disk. Noodle is offline, git-friendly, and keyboard-centric.
      </p>
      
      <div class="install-pill">
        <code>curl -LsSf https://noodlerest.dev/install.sh | sh</code>
        <button class="copy-btn" onclick="navigator.clipboard?.writeText('curl -LsSf https://noodlerest.dev/install.sh | sh'); const t=this.innerText; this.innerText='COPIED'; setTimeout(()=>this.innerText=t, 2000);">COPY</button>
      </div>
      
      <div class="hero-links">
        <a href="/docs/getting-started/installation/">[Quick Start]</a>
        <a href="/docs/">[Read Docs]</a>
        <a href="https://github.com/wilfredinni/noodle" target="_blank">[GitHub]</a>
      </div>
    </div>
    
    <!-- Right Column: TUI Screenshot visual (Bleeds to right edge of screen) -->
    <div class="hero-visual">
      <Image src={exampleImage} class="hero-screenshot" alt="Noodle TUI Workspace" loading="eager" fetchpriority="high" />
      <div class="visual-glow"></div>
    </div>
  </header>

  <!-- Full-width wrapper to let divider lines reach the screen edges -->
  <div class="full-width-yaml-wrapper">
    <!-- Centered section content inside -->
    <section class="local-yaml-section">
      <div class="yaml-left">
        <HeroCode />
      </div>
      <div class="yaml-right">
        <span class="section-tag"># local configuration</span>
        <h2>Your requests are stored locally as simple YAML files, easy to read, easy to version control.</h2>
        <p>
          No heavy databases, no cloud synchronization lock-in, and no proprietary formats.
        </p>
      </div>
    </section>
  </div>

  <main class="tui-container">
    <!-- Features Section (Unique Window-Style TUI Grid) -->
    <section class="features-section">
      <!-- Split Section Header -->
      <div class="section-header">
        <div class="header-left">
          <span class="section-tag"># why noodle</span>
          <h2>Inspect, send, and iterate on requests. Keyboard-only.</h2>
        </div>
        <div class="header-right">
          <p>
            Noodle is built for developers who live in their terminal. No heavy GUI apps, no context switching, and no proprietary formats. Fully offline, git-friendly, and keyboard-centric.
          </p>
        </div>
      </div>

      <!-- Feature TUI Card Grid (Window Style) -->
      <div class="cards-grid">
        <FeatureCard
          filename="collections.yml"
          tag="local"
          title="Git-friendly YAML"
          desc="Noodle stores every request as a single, clean YAML file on disk. No vendor lock-in, easy to version control, and ready to diff or edit with any editor."
          cmd="$ cat collections/get_users.yml"
          accent="var(--color-blue)"
        />
        <FeatureCard
          filename="highlight.json"
          tag="editor"
          title="Tree-sitter highlighting"
          desc="A full-featured code editor with Tree-sitter syntax highlighting, interactive code folding for JSON/YAML blocks, and inline JSON syntax validation."
          cmd="Ctrl+G (Fold) · F5 (Fold All)"
          accent="var(--color-green)"
        />
        <FeatureCard
          filename="variables.env"
          tag="variables"
          title="Smart $var autocomplete"
          desc="Type '$' in any input to trigger a prefix-filtered environment variable dropdown. Resolves variables dynamically with inline color-coded status checks."
          cmd="Type $ in any input field"
          accent="var(--color-orange)"
        />
        <FeatureCard
          filename="remote_copy.sh"
          tag="ssh"
          title="OSC 52 remote clipboard"
          desc="Copy large response bodies directly to your system clipboard even when Noodle is running on remote headless servers over SSH."
          cmd="Ctrl+Y (Copy Response Body)"
          accent="var(--color-purple)"
        />
        <FeatureCard
          filename="auth_payload.json"
          tag="requests"
          title="Deep auth & payload types"
          desc="Supports Bearer, Basic, and API Key auth out-of-the-box. Easily craft JSON, URL-encoded form data, multipart uploads, and binary payloads."
          cmd="$ noodle --env development"
          accent="var(--color-red)"
        />
        <FeatureCard
          filename="config.toml"
          tag="custom"
          title="30+ themes & custom keys"
          desc="Personalize Noodle with over 30 built-in themes (including Catppuccin, Everforest, and Nord) and fully customizable keybindings."
          cmd="$ noodle --theme catppuccin"
          accent="var(--color-yellow)"
        />
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Define extra colors specific to Noodle's styling */
  :root {
    --color-orange: #fab387;
    --color-green: #a6e3a1;
    --color-blue: #89b4fa;
    --color-red: #f38ba8;
    --color-purple: #cba6f7;
    --color-yellow: #f9e2af;
  }

  [data-theme="light"],
  .sl-theme-light {
    --color-orange: #fe640b;
    --color-green: #40a02b;
    --color-blue: #1e66f5;
    --color-red: #d20f39;
    --color-purple: #8839ef;
    --color-yellow: #df8e1d;
  }

  .bg-glow {
    position: fixed;
    top: -20%;
    left: -10%;
    width: 120%;
    height: 120%;
    background: radial-gradient(circle at 50% 0%, var(--accent-glow) 0%, rgba(11, 16, 22, 0) 50%);
    pointer-events: none;
    z-index: -1;
  }

  /* ─── TUI Layout ─── */
  .tui-container {
    display: flex;
    flex-direction: column;
    gap: 4.5rem;
    padding: 3rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  /* ─── Asymmetrical Split Hero ─── */
  .full-width-hero {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
    max-width: 100%;
    padding-left: max(2rem, calc((100vw - 1200px) / 2));
    padding-right: 0;
    margin-top: 4.5rem;
    margin-bottom: 2rem;
    overflow: hidden;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-right: 1rem;
  }

  .hero-tag {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-purple);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-text h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 800;
    line-height: 1.2;
    color: var(--fg);
  }

  .hero-text .lede {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--muted);
  }

  /* Install Pill */
  .install-pill {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg-elevated);
    overflow: hidden;
    max-width: fit-content;
  }
  
  .install-pill code {
    padding: 0.75rem 1.25rem;
    font-size: 0.85rem;
    white-space: nowrap;
    overflow-x: auto;
    color: var(--color-blue);
    display: flex;
    align-items: center;
  }
  
  .install-pill code::before {
    content: "$ ";
    color: var(--muted);
    margin-right: 0.5rem;
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.25rem;
    background: var(--border);
    border: none;
    border-left: 1px solid var(--border);
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .copy-btn:hover {
    background: var(--accent);
    color: var(--bg);
  }

  /* Hero Links */
  .hero-links {
    display: flex;
    gap: 1.5rem;
    margin-top: 0.5rem;
  }

  .hero-links a {
    color: var(--color-purple);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 700;
    transition: color 0.2s;
  }

  .hero-links a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  /* Right Column Code Window (Bleeds to Screen Edge) */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
    min-width: 0;
  }

  .hero-screenshot {
    width: 100%;
    height: auto;
    border: 1px solid var(--border);
    border-right: none;
    border-radius: 8px 0 0 8px;
    box-shadow: -10px 20px 40px rgba(0, 0, 0, 0.35);
    z-index: 2;
    position: relative;
    -webkit-mask-image: linear-gradient(to right, rgba(0,0,0,1) 70%, rgba(0,0,0,0) 100%);
    mask-image: linear-gradient(to right, rgba(0,0,0,1) 70%, rgba(0,0,0,0) 100%);
    display: block;
  }

  /* Soft glow effect behind the screenshot */
  .visual-glow {
    position: absolute;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    z-index: 1;
    filter: blur(20px);
    pointer-events: none;
    opacity: 0.5;
  }

  /* ─── Full-width YAML Section Wrapper ─── */
  .full-width-yaml-wrapper {
    width: 100%;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: transparent;
  }

  .local-yaml-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }

  .yaml-left {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .yaml-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .yaml-right h2 {
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--fg);
    text-align: left;
  }

  .yaml-right p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--muted);
  }

  /* ─── Features Section ─── */
  .features-section {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    margin-top: 1.5rem;
  }

  .section-header {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 2.5rem;
    align-items: end;
  }

  .section-tag {
    font-size: 0.9rem;
    color: var(--color-purple);
    display: block;
    margin-bottom: 0.5rem;
  }

  .section-header h2 {
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--fg);
    text-align: left;
  }

  .header-right p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--muted);
  }

  /* Cards Grid */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* Responsive Adjustments */
  @media (max-width: 900px) {
    .full-width-hero {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
      padding-left: 2rem;
      padding-right: 2rem;
    }

    .install-pill {
      margin: 0 auto;
    }

    .hero-links {
      justify-content: center;
    }

    .hero-screenshot {
      border-right: 1px solid var(--border);
      border-radius: 8px;
    }

    .local-yaml-section {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
      padding: 3rem 2rem;
    }

    .section-header {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
