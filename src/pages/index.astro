---
// Landing page · outside Starlight, full control
import BaseLayout from "../layouts/BaseLayout.astro"
import FeatureCard from "../components/FeatureCard.astro"
import HeroSection from "../components/landing/HeroSection.astro"
import YamlSection from "../components/landing/YamlSection.astro"
import CtaSection from "../components/landing/CtaSection.astro"
import FeatureSection from "../components/landing/FeatureSection.astro"
---

<BaseLayout title="Noodle · Terminal REST Client" description="Inspect, send, and iterate on HTTP requests from YAML files on disk. Built for the terminal.">
  <div class="bg-glow"></div>

  <HeroSection />

  <YamlSection />

  <main class="tui-container">
    <aside class="adoption-proof" aria-label="Open-source project proof">
      <p class="proof-statement"><span>Open source. Local by default.</span> Follow the work before you install.</p>
      <div class="proof-links">
        <a href="/changelog/">Read the release history <span aria-hidden="true">→</span></a>
        <a href="https://github.com/wilfredinni/noodle" target="_blank" rel="noopener noreferrer">Inspect the source <span aria-hidden="true">↗</span><span class="sr-only"> (opens in a new tab)</span></a>
      </div>
    </aside>

    <FeatureSection
      tag="# everyday API work"
      title="Compose requests, keep context close."
      summary="Start with readable request files, organize shared configuration through folders, and switch environments without moving your work into a hosted workspace."
    >
        <FeatureCard
          filename="request.yml"
          tag="requests"
          title="Compose & Send HTTP Requests"
          desc="Craft full requests with URL, headers, params, body, and auth — then send with Ctrl+Enter. JSON, form data, multipart, binary. See response instantly."
          cmd="Send with Ctrl+Enter/J"
          accent="var(--color-blue)"
        />
        <FeatureCard
          filename="folder.yml"
          tag="folders"
          title="Folder Hierarchies & Inheritance"
          desc="Group requests logically. Custom headers and authentication cascade from parent folders down to child requests. Override per-request when needed."
          cmd="Edit a folder to add Auth"
          accent="var(--color-purple)"
        />
        <FeatureCard
          filename="environments.env"
          tag="variables"
          title="Built-in Environment Editor"
          desc="Manage dotenv variables without leaving the terminal. Type '$' in any input for instant autocomplete across URLs, headers, auth, and JSON/YAML bodies."
          cmd="Press e to open Env Editor"
          accent="var(--color-orange)"
        />
    </FeatureSection>

    <FeatureSection
      tag="# keep the workflow moving"
      title="Run, inspect, and bring your team along."
      summary="Automate repeatable checks, keep useful response history nearby, and bring existing OpenAPI or Postman collections into plain files you can own."
      titlePosition="right"
    >
        <FeatureCard
          filename="automation.json"
          tag="automation"
          title="Automation-Ready CLI"
          desc="Create, audit, and run collections from scripts or agent workflows. Get concise terminal summaries or one structured JSON result for reliable automation."
          cmd="$ noodle collection run ./api --json"
          accent="var(--color-red)"
        />
        <FeatureCard
          filename="timeline.log"
          tag="history"
          title="Persistent Response Timeline"
          desc="Every response saved per-request, up to 50 entries deep. Review, compare, and replay past responses from the timeline tab. Never lose a result."
          cmd="Find it in the Request pane"
          accent="var(--color-yellow)"
        />
        <FeatureCard
          filename="openapi.json"
          tag="import"
          title="OpenAPI & Postman Import"
          desc="Migrate collections in seconds. Imports OpenAPI 3.0 specs and Postman 2.1 exports into version-controllable YAML files. Auto-detects format."
          cmd="$ noodle import api.yaml"
          accent="var(--color-green)"
        />
    </FeatureSection>

    <CtaSection />
  </main>
</BaseLayout>

<style>
  /* ─── TUI Layout ─── */
  .tui-container {
    display: flex;
    flex-direction: column;
    padding: 0 2rem;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .adoption-proof {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 2rem;
    align-items: center;
    justify-content: space-between;
    margin: 2rem 0;
    padding: 1rem 0;
    border-top: 1px dashed var(--border);
    border-bottom: 1px dashed var(--border);
  }

  .proof-statement {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .proof-statement span {
    color: var(--color-green);
    font-weight: 700;
  }

  .proof-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
  }

  .proof-links a {
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
  }

  .proof-links a:hover {
    color: var(--fg);
    text-decoration: underline;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 900px) {
    .adoption-proof {
      margin: 2rem 0;
      text-align: center;
      justify-content: center;
    }

    .proof-links {
      justify-content: center;
    }
  }

</style>
