---
// Landing page · outside Starlight, full control
import { Image } from "astro:assets"
import noodleImage from "../assets/noodle.png"
import Nav from "../components/Nav.astro"
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Noodle · Terminal REST Client</title>
    <meta
      name="description"
      content="Inspect, send, and iterate on HTTP requests from YAML files on disk. Built for the terminal."
    />
    <link rel="canonical" href="https://noodlerest.dev" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://noodlerest.dev" />
    <meta property="og:title" content="Noodle · Terminal REST Client" />
    <meta property="og:description" content="Inspect, send, and iterate on HTTP requests from YAML files on disk. Built for the terminal." />
    <meta property="og:image" content="https://noodlerest.dev/noodle.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://noodlerest.dev" />
    <meta name="twitter:title" content="Noodle · Terminal REST Client" />
    <meta name="twitter:description" content="Inspect, send, and iterate on HTTP requests from YAML files on disk. Built for the terminal." />
    <meta name="twitter:image" content="https://noodlerest.dev/noodle.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style is:global>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --bg: #1e1e2e;
        --bg-elevated: #181825;
        --bg-card: rgba(49, 50, 68, 0.7);
        --fg: #cdd6f4;
        --muted: #a6adc8;
        --accent: #b4befe;
        --accent-glow: rgba(180, 190, 254, 0.3);
        --accent-dim: #9399e8;
        --border: #313244;
        --border-hover: #45475a;
        --font-body: 'Inter', system-ui, -apple-system, sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-mono);
        background: var(--bg);
        color: var(--fg);
        line-height: 1.6;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
      }

      .bg-glow {
        position: fixed;
        top: -20%;
        left: -10%;
        width: 120%;
        height: 120%;
        background: radial-gradient(circle at 50% 0%, rgba(46, 139, 148, 0.15) 0%, rgba(11, 16, 22, 0) 50%);
        pointer-events: none;
        z-index: -1;
      }

      nav {
        position: relative;
        z-index: 10;
      }

      /* ─── Hero (Centered Layout) ─── */
      .hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3rem;
        padding: 1.5rem 2rem 6rem;
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
        z-index: 2;
      }

      .hero-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1rem;
        border: 1px solid var(--border);
        font-size: 0.8rem;
        font-family: var(--font-mono);
        color: var(--accent);
        background: rgba(94, 231, 245, 0.05);
        margin-bottom: 2rem;
        transition: border-color 0.2s, background 0.2s;
        text-decoration: none;
      }

      .hero-badge:hover {
        border-color: var(--accent);
        background: rgba(94, 231, 245, 0.1);
      }

      .hero h1 {
        font-family: var(--font-mono);
        font-size: clamp(2.2rem, 3.8vw, 3.2rem);
        font-weight: 400;
        letter-spacing: -0.04em;
        line-height: 1.1;
        text-align: center;
        margin-bottom: 2rem;
      }

      .hero h1 .highlight {
        background: linear-gradient(135deg, var(--fg) 20%, var(--accent) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        position: relative;
      }

      .hero p.lede {
        font-size: 1.1rem;
        color: var(--muted);
        margin-bottom: 0;
        line-height: 1.6;
        font-weight: 400;
      }

      .hero-actions {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        width: 100%;
      }

      .install-block {
        display: flex;
        align-items: stretch;
        width: 100%;
        min-width: 0; /* Flexbox shrink bugfix */
        max-width: 900px;
        border: 1px solid var(--border);
        background: var(--bg-elevated);
        overflow: hidden;
        transition: border-color 0.2s;
      }

      .install-block:hover {
        border-color: var(--border-hover);
      }

      .install-block code {
        display: block; /* Ensure block behavior for overflow scroll */
        flex: 1;
        min-width: 0; /* Prevent flex children from expanding due to nowrap text */
        padding: 1rem 1.25rem;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--fg);
        text-align: left; /* Avoid center-alignment scroll cutoff bug */
        overflow-x: auto;
        white-space: nowrap;
      }

      .install-block .prompt {
        color: var(--accent);
        margin-right: 0.5rem;
        user-select: none;
      }

      .copy-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 1.25rem;
        background: rgba(255, 255, 255, 0.03);
        border: none;
        border-left: 1px solid var(--border);
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.2s;
        font-weight: 600;
      }

      .copy-btn:hover {
        background: rgba(255, 255, 255, 0.08);
        color: var(--fg);
      }

      .secondary-links {
        display: flex;
        gap: 1.5rem;
      }

      .secondary-links a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        transition: color 0.2s;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .secondary-links a:hover {
        color: var(--fg);
      }

      /* ─── Terminal Mockup ─── */
      .hero-visual {
        width: 100%;
        position: relative;
        display: flex; /* FORCE GRID FIX */
        justify-content: center;
        align-items: center;
        margin-top: -2.5rem;
      }


      .terminal-mockup {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        overflow: hidden;
        width: 100%;
      }

      .terminal-mockup img {
        width: 100%;
        display: block;
        height: auto;
      }


      /* ─── Footer ─── */
      footer {
        text-align: center;
        padding: 3rem 2rem;
        color: var(--muted);
        font-size: 0.9rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        margin-top: 4rem;
      }

      footer a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.2s;
      }

      footer a:hover {
        color: var(--fg);
      }

      /* Mobile responsiveness */
      @media (max-width: 900px) {
        .hero {
          gap: 2.2rem;
        }
        .hero-visual {
          margin: -0.7rem auto 0 !important; /* Keep a healthy spacing with the smaller gap */
        }
      }

      @media (max-width: 768px) {
        .hero {
          display: grid;
          grid-template-columns: 1fr;
          padding: 1rem 1rem 4rem;
          overflow-x: hidden;
          gap: 1rem; /* Smaller gaps */
        }

        .hero-content {
          display: contents; /* Flatten grandchildren into grid items */
        }

        .hero h1 {
          grid-row: 1; /* Title first */
          font-size: 1.65rem; /* Smaller title text */
          text-align: center;
          margin-bottom: 0; /* Removed bottom margin */
        }

        .hero-visual {
          grid-row: 2; /* Image second */
          margin: 0 auto 0 !important; /* Set margins to 0 for tightness */
          max-width: 100%;
        }

        .hero p.lede {
          grid-row: 3; /* Subtitle third */
          text-align: center;
          padding: 0 1.5rem;
          font-size: 0.82rem; /* Even smaller subtitle text */
          margin-top: -0.85rem !important; /* Pull subtitle even closer to the image */
          margin-bottom: 1.25rem; /* Space before actions */
        }

        .hero-actions {
          grid-row: 4; /* Actions last */
          width: 100%;
          max-width: 100%;
          min-width: 0;
          align-items: center;
        }

        .install-block {
          max-width: 100%;
          width: 100%;
        }

        .install-block code {
          padding: 0.8rem 1rem;
          font-size: 0.75rem;
          min-width: 0;
          overflow-x: auto;
          white-space: nowrap;
        }

        .copy-btn {
          padding: 0 1rem;
          font-size: 0.7rem;
          flex-shrink: 0; /* Prevent the button from shrinking or clipping */
        }
      }

      /* ─── Installation Widget Styles ─── */
      .installation-two-columns {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 3.5rem;
        width: 100%;
        max-width: 1100px;
        margin: 0 auto;
        align-items: start;
        text-align: left;
      }

      .widget-description-side {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 1.05rem;
        line-height: 1.7;
        padding-top: 0;
      }

      .widget-description-side p {
        margin-left: 0 !important;
        padding-left: 0 !important;
      }

      .widget-description-side p strong {
        color: var(--fg);
        font-weight: 500;
      }

      .hero-actions-container {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        width: 100%;
      }

      .hero-top-buttons {
        display: flex;
        gap: 1rem;
        margin-top: 0.2rem;
        margin-left: 0 !important;
        padding-left: 0 !important;
      }

      .btn-primary, .btn-secondary {
        font-family: var(--font-mono);
        font-size: 0.95rem;
        font-weight: 500;
        padding: 0.65rem 1.75rem;
        border-radius: 4px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        cursor: pointer;
      }

      .btn-primary {
        background-color: var(--accent);
        color: var(--bg);
        border: 1px solid var(--accent);
      }

      .btn-primary:hover {
        background-color: var(--accent-dim);
        border-color: var(--accent-dim);
      }

      .btn-secondary {
        background-color: transparent;
        color: var(--fg);
        border: 1px solid var(--border);
      }

      .btn-secondary:hover {
        border-color: var(--border-hover);
        background-color: rgba(255, 255, 255, 0.02);
      }

      .install-widget {
        display: flex;
        flex-direction: column;
        width: 100%;
        background-color: var(--bg-elevated);
        border: 1px solid var(--border);
        padding: 1.5rem;
        gap: 1.25rem;
        margin-bottom: 1.5rem;
        text-align: left;
      }

      .install-section {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .install-header {
        display: flex;
        align-items: center;
        font-family: var(--font-mono);
      }

      .install-header.justify-between {
        justify-content: space-between;
      }

      .install-header .label {
        font-size: 0.8rem;
        color: var(--muted);
      }

      .tab-buttons {
        display: flex;
        gap: 0.5rem;
      }

      .tab-btn {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--muted);
        padding: 0.25rem 0.65rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        cursor: pointer;
        transition: all 0.2s;
      }

      .tab-btn:hover {
        border-color: var(--border-hover);
        color: var(--fg);
      }

      .tab-btn.active {
        border-color: var(--accent);
        color: var(--fg);
      }

      .install-box {
        display: flex;
        align-items: stretch;
        background-color: var(--bg);
        border: 1px solid var(--border);
        overflow: hidden;
        transition: border-color 0.2s;
      }

      .install-box:hover {
        border-color: var(--border-hover);
      }

      .tab-content {
        display: none;
        flex: 1;
        min-width: 0;
      }

      .tab-content.active {
        display: block;
      }

      .install-box code {
        display: block;
        flex: 1;
        min-width: 0;
        padding: 0.85rem 1.25rem;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--fg);
        overflow-x: auto;
        white-space: nowrap;
      }

      .install-box .prompt {
        color: var(--accent);
        margin-right: 0.5rem;
        user-select: none;
      }

      .copy-widget-btn {
        background: rgba(255, 255, 255, 0.02);
        border: none;
        border-left: 1px solid var(--border);
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0 1.25rem;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .copy-widget-btn:hover {
        background: rgba(255, 255, 255, 0.06);
        color: var(--fg);
      }

      .widget-divider {
        height: 1px;
        background-color: var(--border);
        width: 100%;
        opacity: 0.5;
        margin: 0.25rem 0;
      }

      .preview-docs-link {
        color: var(--accent);
        font-size: 0.8rem;
        text-decoration: none;
        transition: color 0.2s;
      }

      .preview-docs-link:hover {
        color: var(--fg);
        text-decoration: underline;
      }

      .install-footer-info {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--muted);
        text-align: left;
        width: 100%;
      }





      /* Responsive adjustments */
      @media (max-width: 768px) {
        .installation-two-columns {
          grid-template-columns: 1fr;
          gap: 2.5rem;
        }

        .widget-description-side {
          padding-top: 0;
          font-size: 0.95rem;
        }

        .hero-top-buttons {
          width: 100%;
          flex-direction: column;
        }

        .btn-primary, .btn-secondary {
          width: 100%;
        }

        .install-widget {
          padding: 1rem;
        }

        .install-header {
          flex-direction: column;
          align-items: flex-start;
          gap: 0.5rem;
        }

        .tab-buttons {
          margin-left: 0;
          width: 100%;
        }

        .tab-btn {
          flex: 1;
          text-align: center;
        }

        .install-box code {
          padding: 0.75rem 1rem;
          font-size: 0.75rem;
        }

        .copy-widget-btn {
          padding: 0 1rem;
          font-size: 0.7rem;
        }
      }
    </style>
  </head>
  <body>

    <Nav />

    <section class="hero">
      <div class="hero-content">


        <h1>
          A delicious REST client<br />
          for your <span class="highlight">terminal</span>
        </h1>

        <p class="lede">
          Inspect, send, and iterate on HTTP requests from YAML files on disk.
        </p>
      </div>

      <div class="hero-visual" style="width: 100%; max-width: 950px; margin: -2.2rem auto 0;">
        <div class="terminal-mockup">
          <Image src={noodleImage} alt="Noodle Terminal Interface" loading="eager" fetchpriority="high" style="width: 100%; height: auto;" />
        </div>
      </div>

      <div class="hero-content" style="margin-top: -0.5rem; width: 100%; max-width: 1100px; margin-left: auto; margin-right: auto;">

        <div class="installation-two-columns">

          <!-- Left Column: Actions and Widget -->
          <div class="hero-actions-container">
            <!-- Installation Widget -->
            <div class="install-widget">
              <!-- Stable Install Section -->
              <div class="install-section">
                <div class="install-header">
                  <div class="tab-buttons">
                    <button class="tab-btn active" data-tab="script">Script</button>
                    <button class="tab-btn" data-tab="homebrew">Homebrew</button>
                  </div>
                </div>

                <div class="install-box">
                  <div class="tab-content active" id="tab-script">
                    <code><span class="prompt">$</span> curl -LsSf https://noodlerest.dev/install.sh | sh</code>
                  </div>
                  <div class="tab-content" id="tab-homebrew">
                    <code><span class="prompt">$</span> brew tap wilfredinni/noodle && brew install noodle</code>
                  </div>
                  <button class="copy-widget-btn" id="copy-stable-btn">Copy</button>
                </div>
              </div>

              <div class="widget-divider"></div>

              <!-- AI Agent Skill Section -->
              <div class="install-section">
                <div class="install-header">
                  <span class="label">AI Agent Skill</span>
                </div>

                <div class="install-box">
                  <code><span class="prompt">npx</span> skills add wilfredinni/noodle --skill noodle-use -g</code>
                  <button class="copy-widget-btn" id="copy-skill-btn">Copy</button>
                </div>
              </div>
            </div>
          </div>

          <!-- Right Column: Description Text -->
          <div class="widget-description-side">
            <p>Noodle is a <strong>REST client for the terminal</strong>. Your requests are stored locally as simple <strong>YAML files</strong> &mdash; easy to read, easy to <strong>version control</strong>.</p>
            <p><strong>No proprietary formats.</strong> <strong>No accounts.</strong> <strong>No nonsense.</strong></p>

            <!-- Action Buttons -->
            <div class="hero-top-buttons">
              <a href="/docs/getting-started/installation/" class="btn-primary">Quick start</a>
              <a href="/docs/" class="btn-secondary">Read the docs</a>
            </div>
          </div>

        </div>
      </div>

      <script>
        // Interactive Tabs Logic
        const tabs = document.querySelectorAll('.tab-btn');
        const contents = document.querySelectorAll('.tab-content');

        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            tabs.forEach(t => t.classList.remove('active'));
            contents.forEach(c => c.classList.remove('active'));

            tab.classList.add('active');
            const targetId = `tab-${tab.getAttribute('data-tab')}`;
            document.getElementById(targetId)?.classList.add('active');
          });
        });

        // Copy Stable Command Logic
        const copyStableBtn = document.getElementById('copy-stable-btn');
        if (copyStableBtn) {
          copyStableBtn.addEventListener('click', () => {
            const activeContent = document.querySelector('.tab-content.active code');
            if (activeContent) {
              const promptSpan = activeContent.querySelector('.prompt');
              let commandText = activeContent.textContent || '';
              if (promptSpan) {
                const promptText = promptSpan.textContent || '';
                commandText = commandText.replace(promptText, '').trim();
              }
              navigator.clipboard?.writeText(commandText);
              const originalText = copyStableBtn.textContent;
              copyStableBtn.textContent = 'Copied!';
              setTimeout(() => copyStableBtn.textContent = originalText, 2000);
            }
          });
        }

        // Copy Skill Command Logic
        const copySkillBtn = document.getElementById('copy-skill-btn');
        if (copySkillBtn) {
          copySkillBtn.addEventListener('click', () => {
            const codeEl = copySkillBtn.parentElement?.querySelector('code');
            if (codeEl) {
              const promptSpan = codeEl.querySelector('.prompt');
              let commandText = codeEl.textContent || '';
              if (promptSpan) {
                const promptText = promptSpan.textContent || '';
                commandText = commandText.replace(promptText, '').trim();
              }
              navigator.clipboard?.writeText(commandText);
              const originalText = copySkillBtn.textContent;
              copySkillBtn.textContent = 'Copied!';
              setTimeout(() => copySkillBtn.textContent = originalText, 2000);
            }
          });
        }
      </script>
    </section>



    <footer>
      <p>
        MIT Licensed &middot;
        <a href="https://github.com/wilfredinni/noodle">GitHub</a> &middot;
        <a href="/roadmap/">Roadmap</a> &middot;
        <a href="/changelog/">Changelog</a> &middot;
        <a href="https://github.com/wilfredinni/noodle/issues">Issues</a>
      </p>
    </footer>
  </body>
</html>
