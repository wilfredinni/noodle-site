---
import BaseLayout from "../layouts/BaseLayout.astro"
import FeatureCard from "../components/FeatureCard.astro"
import HeroSection from "../components/landing/HeroSection.astro"
import YamlSection from "../components/landing/YamlSection.astro"
import SkillSection from "../components/landing/SkillSection.astro"
import ExtrasSection from "../components/landing/ExtrasSection.astro"
import CtaSection from "../components/landing/CtaSection.astro"
import FeatureSection from "../components/landing/FeatureSection.astro"
---

<BaseLayout title="Noodle · Terminal REST Client" description="Inspect, send, and iterate on HTTP requests from YAML files on disk. Built for the terminal.">
  <HeroSection />
  <YamlSection />

  <main class="tui-container">
    <FeatureSection
      tag="The workflow"
      title="Write it. Version it. Run it."
      summary="Noodle keeps the request itself, its shared configuration, and its repeatable checks in files your team can review and run anywhere."
    >
      <FeatureCard
        tag="Requests"
        title="Compose a real request"
        desc="Define the URL, headers, params, body, and auth in one readable request file—then send it without leaving the terminal."
        cmd="Send with Ctrl+Enter/J"
        accent="var(--color-blue)"
      />
      <FeatureCard
        tag="Shared context"
        title="Keep context beside code"
        desc="Share auth and headers through folders, switch environments, and review every request as plain YAML in Git."
        cmd="Edit a folder to add Auth"
        accent="var(--color-purple)"
      />
      <FeatureCard
        tag="Automation"
        title="Run and audit with confidence"
        desc="Use the CLI in scripts or agent workflows, inspect response history, and audit collections before you share or ship them."
        cmd="$ noodle collection run ."
        accent="var(--color-green)"
      />
    </FeatureSection>

    <SkillSection />
    <ExtrasSection />
    <CtaSection />
  </main>
</BaseLayout>

<style>
  .tui-container {
    display: flex;
    flex-direction: column;
    padding: 0 2rem;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  @media (max-width: 520px) {
    .tui-container {
      padding: 0 1.25rem;
    }
  }
</style>
