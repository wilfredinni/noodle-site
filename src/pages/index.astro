---
// Landing page · outside Starlight, full control
import BaseLayout from "../layouts/BaseLayout.astro"
import FeatureCard from "../components/FeatureCard.astro"
import HeroSection from "../components/landing/HeroSection.astro"
import YamlSection from "../components/landing/YamlSection.astro"
import ThemesSection from "../components/landing/ThemesSection.astro"
import SkillSection from "../components/landing/SkillSection.astro"
import CtaSection from "../components/landing/CtaSection.astro"
---

<BaseLayout title="Noodle · Terminal REST Client" description="Inspect, send, and iterate on HTTP requests from YAML files on disk. Built for the terminal.">
  <div class="bg-glow"></div>

  <HeroSection />

  <YamlSection />

  <main class="tui-container">
    <!-- Primary features — denser product beat -->
    <section class="features-section features-primary" aria-labelledby="features-heading">
      <header class="section-head">
        <span class="section-tag"># features</span>
        <h2 id="features-heading">Built for the request loop.</h2>
        <p class="section-lede">
          Compose, organize, and parameterize without leaving the terminal.
        </p>
      </header>

      <div class="cards-grid">
        <FeatureCard
          filename="request.yml"
          tag="requests"
          title="Compose & Send HTTP Requests"
          desc="Craft full requests with URL, headers, params, body, and auth — then send with Ctrl+Enter. JSON, form data, multipart, binary. See response instantly."
          cmd="Send with Ctrl+Enter/J"
          accent="var(--color-blue)"
        />
        <FeatureCard
          filename="folder.yml"
          tag="folders"
          title="Folder Hierarchies & Inheritance"
          desc="Group requests logically. Custom headers and authentication cascade from parent folders down to child requests. Override per-request when needed."
          cmd="Edit a folder to add Auth"
          accent="var(--color-purple)"
        />
        <FeatureCard
          filename="environments.env"
          tag="variables"
          title="Built-in Environment Editor"
          desc="Type '$' in any input for instant environment variable autocompletion. Easily manage and update variables with the built-in dotenv environment editor."
          cmd="Press e to open Env Editor"
          accent="var(--color-orange)"
        />
      </div>
    </section>

    <ThemesSection />

    <!-- Secondary capabilities — lighter density so themes stays the peak -->
    <section class="features-section features-secondary" aria-labelledby="more-features-heading">
      <header class="section-head section-head-inline">
        <span class="section-tag"># also included</span>
        <h2 id="more-features-heading">Power tools when you need them.</h2>
      </header>

      <div class="features-strip">
        <article class="strip-item" style="--accent-color: var(--color-red);">
          <span class="strip-tag">autocomplete</span>
          <h3>Powerful Env Autocomplete</h3>
          <p>
            Context-aware suggestions for params, headers, variables, and JSON/YAML bodies as you type.
          </p>
          <code class="strip-cmd">Type $ for variables</code>
        </article>
        <article class="strip-item" style="--accent-color: var(--color-yellow);">
          <span class="strip-tag">history</span>
          <h3>Persistent Response Timeline</h3>
          <p>
            Every response saved per-request, up to 50 deep. Review, compare, and replay from the timeline tab.
          </p>
          <code class="strip-cmd">Request pane → Timeline</code>
        </article>
        <article class="strip-item" style="--accent-color: var(--color-green);">
          <span class="strip-tag">import</span>
          <h3>OpenAPI & Postman Import</h3>
          <p>
            Migrate collections in seconds into version-controllable YAML. Auto-detects OpenAPI 3.0 and Postman 2.1.
          </p>
          <code class="strip-cmd">$ noodle import api.yaml</code>
        </article>
      </div>
    </section>

    <SkillSection />

    <CtaSection />
  </main>
</BaseLayout>

<style>
  /* ─── TUI Layout ─── */
  .tui-container {
    display: flex;
    flex-direction: column;
    padding: 0 2rem;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    gap: 0;
  }

  /* Shared section chrome */
  .section-head {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 40rem;
    margin-bottom: 0.25rem;
  }

  .section-head-inline {
    max-width: none;
    margin-bottom: 0;
  }

  .section-tag {
    font-size: 0.9rem;
    color: var(--color-purple);
    display: block;
  }

  .section-head h2,
  .section-head-inline h2 {
    font-size: clamp(1.35rem, 2.2vw, 1.85rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--fg);
  }

  .section-lede {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--muted);
    max-width: 36rem;
  }

  /* ─── Features: primary (tight product beat) ─── */
  .features-primary {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 3.5rem 0 2rem;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  /* ─── Features: secondary (lighter strip after themes) ─── */
  .features-secondary {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem 0 3.5rem;
  }

  .features-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .strip-item {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 1.2rem 1.25rem;
    min-width: 0;
    background: color-mix(in srgb, var(--bg-card) 85%, var(--bg));
    border: 1px solid var(--border);
    border-radius: 6px;
    box-shadow: 3px 3px 0 var(--border);
    border-top: 2px solid var(--accent-color);
  }

  .strip-tag {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-color);
  }

  .strip-item h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--fg);
    line-height: 1.3;
  }

  .strip-item p {
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--muted);
    flex-grow: 1;
  }

  .strip-cmd {
    display: inline-block;
    width: fit-content;
    max-width: 100%;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.4rem 0.65rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 900px) {
    .features-primary {
      padding: 2.5rem 0 1.5rem;
      gap: 1.5rem;
    }

    .features-secondary {
      padding: 1.5rem 0 2.5rem;
    }

    .cards-grid,
    .features-strip {
      grid-template-columns: 1fr;
    }

    .section-head,
    .section-head-inline {
      text-align: center;
      align-items: center;
    }

    .section-lede {
      text-align: center;
    }
  }
</style>
