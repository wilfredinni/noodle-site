---
// Landing page · outside Starlight, full control
import BaseLayout from "../layouts/BaseLayout.astro"
import FeatureCard from "../components/FeatureCard.astro"
import HeroCode from "../components/HeroCode.astro"
import { Image } from "astro:assets"
import exampleImage from "../assets/example.png"
import themesImage from "../assets/themes.png"
---

<BaseLayout title="Noodle · Terminal REST Client" description="Inspect, send, and iterate on HTTP requests from YAML files on disk. Built for the terminal.">
  <div class="bg-glow"></div>
  
  <!-- Full-width hero outside the container (aligned left, bleeds right) -->
  <header class="full-width-hero">
    <!-- Left Column: Typography, Install Command, and Links -->
    <div class="hero-text">
      <span class="hero-tag"># terminal rest client</span>
      <h1>A delicious REST client that lives in your terminal.</h1>
      <p class="lede">
        Inspect, send, and iterate on HTTP requests from YAML files on disk. Noodle is offline, git-friendly, and keyboard-centric.
      </p>
      
      <div class="install-pill">
        <code>curl -LsSf https://noodlerest.dev/install.sh | sh</code>
        <button class="copy-btn" onclick="navigator.clipboard?.writeText('curl -LsSf https://noodlerest.dev/install.sh | sh'); const t=this.innerText; this.innerText='COPIED'; setTimeout(()=>this.innerText=t, 2000);">COPY</button>
      </div>
      
      <div class="hero-links">
        <a href="/docs/getting-started/installation/">[Quick Start]</a>
        <a href="/docs/">[Read Docs]</a>
        <a href="#ai-skill">[Skill]</a>
      </div>
    </div>
    
    <!-- Right Column: TUI Screenshot visual (Bleeds to right edge of screen) -->
    <div class="hero-visual">
      <Image src={exampleImage} class="hero-screenshot" alt="Noodle TUI Workspace" loading="eager" fetchpriority="high" />
      <div class="visual-glow"></div>
    </div>
  </header>

  <!-- Full-width wrapper to let divider lines reach the screen edges -->
  <div class="full-width-yaml-wrapper">
    <!-- Centered section content inside -->
    <section class="local-yaml-section">
      <div class="yaml-left">
        <HeroCode />
      </div>
      <div class="yaml-right">
        <span class="section-tag"># noodle is for you</span>
        <h2>Your requests are stored locally as simple YAML files, easy to read, easy to version control.</h2>
        <p>
          No heavy databases, no cloud synchronization lock-in, and no proprietary formats.
        </p>
      </div>
    </section>
  </div>

  <main class="tui-container">
    <!-- Features Section (Unique Window-Style TUI Grid) -->
    <section class="features-section">
      <!-- Feature TUI Card Grid (Window Style) -->
      <div class="cards-grid">
        <FeatureCard
          filename="request.yml"
          tag="requests"
          title="Compose & Send HTTP Requests"
          desc="Craft full requests with URL, headers, params, body, and auth — then send with Ctrl+Enter. JSON, form data, multipart, binary. See response instantly."
          cmd="Send with Ctrl+Enter/J"
          accent="var(--color-blue)"
        />
        <FeatureCard
          filename="folder.yml"
          tag="folders"
          title="Folder Hierarchies & Inheritance"
          desc="Group requests logically. Custom headers and authentication cascade from parent folders down to child requests. Override per-request when needed."
          cmd="Edit a folder to add Auth"
          accent="var(--color-purple)"
        />
        <FeatureCard
          filename="environments.env"
          tag="variables"
          title="Built-in Environment Editor"
          desc="Type '$' in any input for instant environment variable autocompletion. Easily manage and update variables with the built-in dotenv environment editor."
          cmd="Press e to open Env Editor"
          accent="var(--color-orange)"
        />
      </div>
    </section>

    <!-- Themes Section -->
    <section class="themes-section">
      <div class="themes-left">
        <span class="section-tag"># personalization</span>
        <h2>30+ built-in themes to match your workspace.</h2>
        <p>
          Noodle comes pre-packaged with over 30 beautiful themes (including Catppuccin, Everforest, Nord, and Tokyo Night). Give your terminal some personality and work in a space that feels uniquely yours.
        </p>
      </div>

      <div class="themes-right">
        <div class="themes-visual">
          <Image src={themesImage} class="themes-screenshot" alt="Noodle Themes Collection" loading="lazy" />
          <div class="visual-glow"></div>
        </div>
      </div>
    </section>

    <!-- More Features Section -->
    <section class="features-section">
      <div class="cards-grid">
        <FeatureCard
          filename="autocomplete.json"
          tag="autocomplete"
          title="Powerful Env Autocomplete"
          desc="Autocomplete for params, headers, variables, and JSON/YAML bodies. Context-aware suggestions are generated dynamically as you type in any field."
          cmd="Type $ for variables autocomplete"
          accent="var(--color-red)"
        />
        <FeatureCard
          filename="timeline.log"
          tag="history"
          title="Persistent Response Timeline"
          desc="Every response saved per-request, up to 50 entries deep. Review, compare, and replay past responses from the timeline tab. Never lose a result."
          cmd="Find it in the Request pane"
          accent="var(--color-yellow)"
        />
        <FeatureCard
          filename="openapi.json"
          tag="import"
          title="OpenAPI & Postman Import"
          desc="Migrate collections in seconds. Imports OpenAPI 3.0 specs and Postman 2.1 exports into version-controllable YAML files. Auto-detects format."
          cmd="$ noodle import api.yaml"
          accent="var(--color-green)"
        />
      </div>
    </section>

    <!-- Skill Section -->
    <section class="skill-section" id="ai-skill">
      <div class="skill-left">
        <div class="skill-visual">
          <HeroCode filename="# example prompts">
            <div class="mock-line"><span class="mock-key">&gt;</span> Scaffold Stripe API collection</div>
            <div class="mock-line"><span class="mock-key">&gt;</span> Audit my collection for security</div>
            <div class="mock-line"><span class="mock-key">&gt;</span> Convert Insomnia export to Noodle</div>
            <div class="mock-line"><span class="mock-key">&gt;</span> Set up basic auth on Posts folder</div>
            <div class="mock-line"><span class="mock-key">&gt;</span> Change expand layout keybinding to Alt+I</div>
            <div class="mock-line"><span class="mock-key">&gt;</span> Set Catppuccin as my theme</div>
            <div class="mock-line"><span class="mock-key">&gt;</span> How many requests are in the Stripe collection?</div>
            <div class="mock-line"><span class="mock-key">&gt;</span> What's the average login response time?</div>
            <div class="mock-line"><span class="mock-key">&gt;</span> Sort folders from Z to A</div>
            <div class="mock-line"><span class="mock-key">&gt;</span> Add a GET request for user profiles</div>
            <div class="mock-line"><span class="mock-key">&gt;</span> Update variables in development env</div>
          </HeroCode>
          <div class="visual-glow"></div>
        </div>
      </div>

      <div class="skill-right">
        <span class="section-tag"># ai agent skill</span>
        <h2>Supercharge your AI coding assistants.</h2>
        <p>
          Add Noodle to your agent's toolkit. Enable AI assistants to scaffold, edit, and audit collections natively.
        </p>
        <div class="install-pill">
          <code>npx skills add wilfredinni/noodle --skill noodle-use -g</code>
          <button class="copy-btn" onclick="navigator.clipboard?.writeText('npx skills add wilfredinni/noodle --skill noodle-use -g'); const t=this.innerText; this.innerText='COPIED'; setTimeout(()=>this.innerText=t, 2000);">COPY</button>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <span class="section-tag"># get started</span>
      <h2>Build your next collection today.</h2>
      <p>
        Noodle is free, open-source, and runs entirely in your terminal. Get up and running in less than 10 seconds.
      </p>
      <div class="cta-links">
        <a href="/docs/getting-started/installation/">[Install Noodle]</a>
        <a href="https://github.com/wilfredinni/noodle" target="_blank">[Star on GitHub]</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Define extra colors specific to Noodle's styling */
  :root {
    --color-orange: #fab387;
    --color-green: #a6e3a1;
    --color-blue: #89b4fa;
    --color-red: #f38ba8;
    --color-purple: #cba6f7;
    --color-yellow: #f9e2af;
  }

  [data-theme="light"],
  .sl-theme-light {
    --color-orange: #fe640b;
    --color-green: #40a02b;
    --color-blue: #1e66f5;
    --color-red: #d20f39;
    --color-purple: #8839ef;
    --color-yellow: #df8e1d;
  }

  .bg-glow {
    position: fixed;
    top: -20%;
    left: -10%;
    width: 120%;
    height: 120%;
    background: radial-gradient(circle at 50% 0%, var(--accent-glow) 0%, rgba(11, 16, 22, 0) 50%);
    pointer-events: none;
    z-index: -1;
  }

  /* ─── TUI Layout ─── */
  .tui-container {
    display: flex;
    flex-direction: column;
    padding: 0 2rem;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  /* ─── Asymmetrical Split Hero ─── */
  .full-width-hero {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
    max-width: 1440px;
    min-height: calc(100vh - 58px);
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 0;
    overflow: hidden;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-right: 1rem;
  }

  .hero-tag {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-purple);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-text h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 800;
    line-height: 1.2;
    color: var(--fg);
  }

  .hero-text .lede {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--muted);
  }

  /* Install Pill */
  .install-pill {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg-elevated);
    overflow: hidden;
    max-width: fit-content;
  }
  
  .install-pill code {
    padding: 0.75rem 1.25rem;
    font-size: 0.85rem;
    white-space: nowrap;
    overflow-x: auto;
    color: var(--color-blue);
    display: flex;
    align-items: center;
    scrollbar-width: none; /* Firefox */
  }

  .install-pill code::-webkit-scrollbar {
    display: none; /* Safari and Chrome */
  }
  
  .install-pill code::before {
    content: "$ ";
    color: var(--muted);
    margin-right: 0.5rem;
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.25rem;
    background: var(--border);
    border: none;
    border-left: 1px solid var(--border);
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .copy-btn:hover {
    background: var(--accent);
    color: var(--bg);
  }

  /* Hero Links */
  .hero-links {
    display: flex;
    gap: 1.5rem;
    margin-top: 0.5rem;
  }

  .hero-links a {
    color: var(--color-purple);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 700;
    transition: color 0.2s;
  }

  .hero-links a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  /* Right Column Code Window (Bleeds to Screen Edge) */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
    min-width: 0;
  }

  .hero-screenshot {
    width: 100%;
    max-width: 100%;
    height: auto;
    border: 1px solid var(--border);
    border-right: none;
    border-radius: 8px 0 0 8px;
    box-shadow: -10px 20px 40px rgba(0, 0, 0, 0.35);
    z-index: 2;
    position: relative;
    -webkit-mask-image: linear-gradient(to right, rgba(0,0,0,1) 70%, rgba(0,0,0,0) 100%);
    mask-image: linear-gradient(to right, rgba(0,0,0,1) 70%, rgba(0,0,0,0) 100%);
    display: block;
  }

  /* Soft glow effect behind the screenshot */
  .visual-glow {
    position: absolute;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    z-index: 1;
    filter: blur(20px);
    pointer-events: none;
    opacity: 0.5;
  }

  /* ─── Full-width YAML Section Wrapper ─── */
  .full-width-yaml-wrapper {
    width: 100%;
    background: transparent;
  }

  .local-yaml-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 4rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }

  .yaml-left {
    display: flex;
    justify-content: center;
    width: 100%;
    min-width: 0;
  }

  .yaml-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .yaml-right h2 {
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--fg);
    text-align: left;
  }

  .yaml-right p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--muted);
  }

  /* ─── Features Section ─── */
  .features-section {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding: 2.5rem 0;
  }

  /* ─── Themes Section ─── */
  .themes-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 4rem;
    align-items: center;
    padding: 2.5rem 0;
  }

  .themes-left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .themes-left h2 {
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--fg);
    text-align: left;
  }

  .themes-left p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--muted);
  }

  .themes-right {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .themes-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .themes-screenshot {
    width: 100%;
    max-width: 100%;
    max-height: 300px;
    object-fit: cover;
    object-position: top left;
    border: 1px solid var(--border);
    border-right: none;
    border-radius: 8px 0 0 8px;
    box-shadow: -10px 20px 40px rgba(0, 0, 0, 0.35);
    z-index: 2;
    position: relative;
    -webkit-mask-image: linear-gradient(to right, rgba(0,0,0,1) 70%, rgba(0,0,0,0) 100%);
    mask-image: linear-gradient(to right, rgba(0,0,0,1) 70%, rgba(0,0,0,0) 100%);
    display: block;
  }



  .mock-key {
    color: var(--color-blue);
    font-weight: bold;
  }

  .mock-value {
    color: var(--color-green);
  }

  /* ─── Skill Section ─── */
  .skill-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 4rem;
    align-items: center;
    padding: 2.5rem 0;
  }

  .skill-left {
    display: flex;
    justify-content: center;
    width: 100%;
    min-width: 0;
  }

  .skill-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    min-width: 0;
  }

  .skill-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skill-right h2 {
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--fg);
    text-align: left;
  }

  .skill-right p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--muted);
  }

  .skill-right .install-pill {
    margin-top: 0.5rem;
  }

  .section-tag {
    font-size: 0.9rem;
    color: var(--color-purple);
    display: block;
    margin-bottom: 0.5rem;
  }

  /* ─── CTA Section ─── */
  .cta-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
    padding: 5rem 0 3rem 0;
    border-top: 1px dashed var(--border);
    margin-top: 2rem;
  }

  .cta-section h2 {
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--fg);
    max-width: 600px;
  }

  .cta-section p {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--muted);
    max-width: 600px;
  }

  .cta-links {
    display: flex;
    gap: 2rem;
    margin-top: 1rem;
  }

  .cta-links a {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    transition: color 0.2s;
  }

  .cta-links a:first-child {
    color: var(--color-green);
  }

  .cta-links a:first-child:hover {
    color: var(--fg);
    text-decoration: underline;
  }

  .cta-links a:last-child {
    color: var(--color-purple);
  }

  .cta-links a:last-child:hover {
    color: var(--fg);
    text-decoration: underline;
  }

  /* Cards Grid */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* Responsive Adjustments */
  @media (max-width: 900px) {
    .full-width-hero {
      grid-template-columns: minmax(0, 1fr);
      gap: 2.5rem;
      text-align: center;
      padding-left: 2rem;
      padding-right: 2rem;
      min-height: auto;
      margin-top: 2.5rem;
      margin-bottom: 2.5rem;
    }

    .install-pill {
      margin: 0 auto;
      max-width: 100%;
      width: 100%;
    }

    .hero-links {
      justify-content: center;
    }

    .hero-screenshot,
    .themes-screenshot {
      border-right: 1px solid var(--border);
      border-radius: 8px;
      -webkit-mask-image: none;
      mask-image: none;
    }

    .local-yaml-section {
      grid-template-columns: minmax(0, 1fr);
      gap: 2rem;
      text-align: center;
      padding: 3rem 2rem;
    }

     .features-section {
       padding: 3rem 0;
     }

     .themes-section {
       grid-template-columns: minmax(0, 1fr);
       gap: 2rem;
       text-align: center;
       padding: 3rem 0;
     }

     .themes-left h2,
     .yaml-right h2 {
       text-align: center;
     }

     .skill-section {
       grid-template-columns: minmax(0, 1fr);
       gap: 2rem;
       text-align: center;
       padding: 3rem 0;
     }

    .skill-right h2 {
      text-align: center;
    }

    .skill-right .install-pill {
      margin: 0.5rem auto 0 auto;
    }

    .yaml-left {
      order: 2;
    }

    .yaml-right {
      order: 1;
    }

    .skill-left {
      order: 2;
    }

    .skill-right {
      order: 1;
    }

    .cta-section {
      padding: 3rem 0;
      gap: 1.25rem;
    }

    .cta-links {
      flex-direction: column;
      gap: 1rem;
    }


    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
