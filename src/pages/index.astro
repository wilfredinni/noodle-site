---
// Landing page · outside Starlight, full control
import BaseLayout from "../layouts/BaseLayout.astro"
import FeatureCard from "../components/FeatureCard.astro"
---

<BaseLayout title="Noodle · Terminal REST Client" description="Inspect, send, and iterate on HTTP requests from YAML files on disk. Built for the terminal.">
  <div class="bg-glow"></div>
  
  <main class="tui-container">
    <!-- Restored TUI Welcome Panel Header -->
    <div class="tui-panel hero-panel">
      <div class="tui-panel-header">
        <span>~/noodle/welcome</span>
        <span class="tui-status">[OK]</span>
      </div>
      <div class="tui-panel-content">
         <h1><span class="prompt">$</span> noodle --info<span class="blinking-cursor">&nbsp;</span></h1>
         <p class="lede">A delicious REST client that lives in your terminal.</p>
         
         <div class="install-pane">
           <code>curl -LsSf https://noodlerest.dev/install.sh | sh</code>
           <button class="copy-btn" onclick="navigator.clipboard?.writeText('curl -LsSf https://noodlerest.dev/install.sh | sh'); const t=this.innerText; this.innerText='COPIED'; setTimeout(()=>this.innerText=t, 2000);">COPY</button>
         </div>
         
         <div class="secondary-links">
           <a href="/docs/getting-started/installation/">[Quick Start]</a>
           <a href="/docs/">[Read Docs]</a>
         </div>
      </div>
    </div>

    <!-- Features Section (Unique Window-Style TUI Grid) -->
    <section class="features-section">
      <!-- Split Section Header -->
      <div class="section-header">
        <div class="header-left">
          <span class="section-tag"># why noodle</span>
          <h2>Inspect, send, and iterate on requests. Keyboard-only.</h2>
        </div>
        <div class="header-right">
          <p>
            Noodle is built for developers who live in their terminal. No heavy GUI apps, no context switching, and no proprietary formats. Fully offline, git-friendly, and keyboard-centric.
          </p>
        </div>
      </div>

      <!-- Feature TUI Card Grid (Window Style) -->
      <div class="cards-grid">
        <FeatureCard
          filename="collections.yml"
          tag="local"
          title="Git-friendly YAML"
          desc="Noodle stores every request as a single, clean YAML file on disk. No vendor lock-in, easy to version control, and ready to diff or edit with any editor."
          cmd="$ cat collections/get_users.yml"
          accent="var(--color-blue)"
        />
        <FeatureCard
          filename="highlight.json"
          tag="editor"
          title="Tree-sitter highlighting"
          desc="A full-featured code editor with Tree-sitter syntax highlighting, interactive code folding for JSON/YAML blocks, and inline JSON syntax validation."
          cmd="Ctrl+G (Fold) · F5 (Fold All)"
          accent="var(--color-green)"
        />
        <FeatureCard
          filename="variables.env"
          tag="variables"
          title="Smart $var autocomplete"
          desc="Type '$' in any input to trigger a prefix-filtered environment variable dropdown. Resolves variables dynamically with inline color-coded status checks."
          cmd="Type $ in any input field"
          accent="var(--color-orange)"
        />
        <FeatureCard
          filename="remote_copy.sh"
          tag="ssh"
          title="OSC 52 remote clipboard"
          desc="Copy large response bodies directly to your system clipboard even when Noodle is running on remote headless servers over SSH."
          cmd="Ctrl+Y (Copy Response Body)"
          accent="var(--color-purple)"
        />
        <FeatureCard
          filename="auth_payload.json"
          tag="requests"
          title="Deep auth & payload types"
          desc="Supports Bearer, Basic, and API Key auth out-of-the-box. Easily craft JSON, URL-encoded form data, multipart uploads, and binary payloads."
          cmd="$ noodle --env development"
          accent="var(--color-red)"
        />
        <FeatureCard
          filename="config.toml"
          tag="custom"
          title="30+ themes & custom keys"
          desc="Personalize Noodle with over 30 built-in themes (including Catppuccin, Everforest, and Nord) and fully customizable keybindings."
          cmd="$ noodle --theme catppuccin"
          accent="var(--color-yellow)"
        />
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Define extra colors specific to Noodle's styling */
  :root {
    --color-orange: #fab387;
    --color-green: #a6e3a1;
    --color-blue: #89b4fa;
    --color-red: #f38ba8;
    --color-purple: #cba6f7;
    --color-yellow: #f9e2af;
  }

  [data-theme="light"],
  .sl-theme-light {
    --color-orange: #fe640b;
    --color-green: #40a02b;
    --color-blue: #1e66f5;
    --color-red: #d20f39;
    --color-purple: #8839ef;
    --color-yellow: #df8e1d;
  }

  .bg-glow {
    position: fixed;
    top: -20%;
    left: -10%;
    width: 120%;
    height: 120%;
    background: radial-gradient(circle at 50% 0%, var(--accent-glow) 0%, rgba(11, 16, 22, 0) 50%);
    pointer-events: none;
    z-index: -1;
  }

  /* ─── TUI Layout ─── */
  .tui-container {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  /* Panels & Cards use retro solid block-shadows instead of soft glows */
  .tui-panel {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 6px 6px 0 var(--border);
    display: flex;
    flex-direction: column;
  }

  .tui-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    background: var(--border);
    font-size: 0.85rem;
    color: var(--fg);
    border-bottom: 1px solid var(--border);
  }
  
  .tui-panel-header .tui-status {
    color: var(--color-green);
  }

  .tui-panel-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Hero Specific */
  .hero-panel h1 {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--fg);
  }
  
  .hero-panel .prompt {
    color: var(--color-green);
    margin-right: 0.5rem;
  }
  
  .blinking-cursor {
    display: inline-block;
    width: 12px;
    background-color: var(--accent);
    animation: blink 1s step-end infinite;
  }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-panel .lede {
    font-size: 1.15rem;
    color: var(--muted);
  }

  /* Installation Pane */
  .install-pane {
    margin-top: 1rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
    overflow: hidden;
    display: flex;
    align-items: stretch;
  }
  
  .install-pane code {
    flex: 1;
    padding: 1rem;
    font-size: 0.9rem;
    overflow-x: auto;
    white-space: nowrap;
    color: var(--color-blue);
  }
  
  .install-pane code::before {
    content: "$ ";
    color: var(--muted);
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.5rem;
    background: var(--border);
    border: none;
    border-left: 1px solid var(--border);
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .copy-btn:hover {
    background: var(--accent);
    color: var(--bg);
  }

  /* Links */
  .secondary-links {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .secondary-links a {
    color: var(--color-purple);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 700;
    transition: color 0.2s;
  }

  .secondary-links a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  /* ─── Features Section ─── */
  .features-section {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    margin-top: 1.5rem;
  }

  .section-header {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 2.5rem;
    align-items: end;
  }

  .section-tag {
    font-size: 0.9rem;
    color: var(--color-purple);
    display: block;
    margin-bottom: 0.5rem;
  }

  .section-header h2 {
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--fg);
    text-align: left;
  }

  .header-right p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--muted);
  }

  /* Cards Grid */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* Responsive Adjustments */
  @media (max-width: 900px) {
    .section-header {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Hover overrides for welcome panel */
  .tui-panel:not(.hero-panel):hover {
    border-color: var(--border-hover);
    box-shadow: 0 10px 30px var(--accent-glow);
  }
  
  .hero-panel {
    transition: none;
  }
</style>
