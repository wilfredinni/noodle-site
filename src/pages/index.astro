---
// Landing page · outside Starlight, full control
import BaseLayout from "../layouts/BaseLayout.astro"
---

<BaseLayout title="Noodle · Terminal REST Client" description="Inspect, send, and iterate on HTTP requests from YAML files on disk. Built for the terminal.">
  <div class="bg-glow"></div>
  
  <main class="tui-container">
    <!-- Restored TUI Welcome Panel Header -->
    <div class="tui-panel hero-panel">
      <div class="tui-panel-header">
        <span>~/noodle/welcome</span>
        <span class="tui-status">[OK]</span>
      </div>
      <div class="tui-panel-content">
         <h1><span class="prompt">$</span> noodle --info<span class="blinking-cursor">&nbsp;</span></h1>
         <p class="lede">A delicious REST client that lives in your terminal.</p>
         
         <div class="install-pane">
           <code>curl -LsSf https://noodlerest.dev/install.sh | sh</code>
           <button class="copy-btn" onclick="navigator.clipboard?.writeText('curl -LsSf https://noodlerest.dev/install.sh | sh'); const t=this.innerText; this.innerText='COPIED'; setTimeout(()=>this.innerText=t, 2000);">COPY</button>
         </div>
         
         <div class="secondary-links">
           <a href="/docs/getting-started/installation/">[Quick Start]</a>
           <a href="/docs/">[Read Docs]</a>
         </div>
      </div>
    </div>

    <!-- Features Section (Unique Window-Style TUI Grid) -->
    <section class="features-section">
      <!-- Split Section Header -->
      <div class="section-header">
        <div class="header-left">
          <span class="section-tag"># why noodle</span>
          <h2>Inspect, send, and iterate on requests. Keyboard-only.</h2>
        </div>
        <div class="header-right">
          <p>
            Noodle is built for developers who live in their terminal. No heavy GUI apps, no context switching, and no proprietary formats. Fully offline, git-friendly, and keyboard-centric.
          </p>
        </div>
      </div>

      <!-- Feature TUI Card Grid (Window Style) -->
      <div class="cards-grid">
        <!-- Card 1: Local / Git Friendly -->
        <div class="tui-card" style="--accent-color: var(--color-blue);">
          <div class="card-header">
            <span>📄 collections.yml</span>
            <div class="card-controls"><span>-</span><span>□</span><span>×</span></div>
          </div>
          <div class="card-body">
            <span class="card-tag">local</span>
            <h3>Git-friendly YAML</h3>
            <p class="card-desc">
              Noodle stores every request as a single, clean YAML file on disk. No vendor lock-in, easy to version control, and ready to diff or edit with any editor.
            </p>
            <div class="card-cmd">
              <code>$ cat collections/get_users.yml</code>
            </div>
          </div>
        </div>

        <!-- Card 2: Tree-sitter Editor -->
        <div class="tui-card" style="--accent-color: var(--color-green);">
          <div class="card-header">
            <span>📄 highlight.json</span>
            <div class="card-controls"><span>-</span><span>□</span><span>×</span></div>
          </div>
          <div class="card-body">
            <span class="card-tag">editor</span>
            <h3>Tree-sitter highlighting</h3>
            <p class="card-desc">
              A full-featured code editor with Tree-sitter syntax highlighting, interactive code folding for JSON/YAML blocks, and inline JSON syntax validation.
            </p>
            <div class="card-cmd">
              <code>Ctrl+G (Fold) · F5 (Fold All)</code>
            </div>
          </div>
        </div>

        <!-- Card 3: Autocomplete -->
        <div class="tui-card" style="--accent-color: var(--color-orange);">
          <div class="card-header">
            <span>📄 variables.env</span>
            <div class="card-controls"><span>-</span><span>□</span><span>×</span></div>
          </div>
          <div class="card-body">
            <span class="card-tag">variables</span>
            <h3>Smart $var autocomplete</h3>
            <p class="card-desc">
              Type '$' in any input to trigger a prefix-filtered environment variable dropdown. Resolves variables dynamically with inline color-coded status checks.
            </p>
            <div class="card-cmd">
              <code>Type $ in any input field</code>
            </div>
          </div>
        </div>

        <!-- Card 4: SSH Support -->
        <div class="tui-card" style="--accent-color: var(--color-purple);">
          <div class="card-header">
            <span>📄 remote_copy.sh</span>
            <div class="card-controls"><span>-</span><span>□</span><span>×</span></div>
          </div>
          <div class="card-body">
            <span class="card-tag">ssh</span>
            <h3>OSC 52 remote clipboard</h3>
            <p class="card-desc">
              Copy large response bodies directly to your system clipboard even when Noodle is running on remote headless servers over SSH.
            </p>
            <div class="card-cmd">
              <code>Ctrl+Y (Copy Response Body)</code>
            </div>
          </div>
        </div>

        <!-- Card 5: Auth & Body Types -->
        <div class="tui-card" style="--accent-color: var(--color-red);">
          <div class="card-header">
            <span>📄 auth_payload.json</span>
            <div class="card-controls"><span>-</span><span>□</span><span>×</span></div>
          </div>
          <div class="card-body">
            <span class="card-tag">requests</span>
            <h3>Deep auth & payload types</h3>
            <p class="card-desc">
              Supports Bearer, Basic, and API Key auth out-of-the-box. Easily craft JSON, URL-encoded form data, multipart uploads, and binary payloads.
            </p>
            <div class="card-cmd">
              <code>$ noodle --env development</code>
            </div>
          </div>
        </div>

        <!-- Card 6: Customization -->
        <div class="tui-card" style="--accent-color: var(--color-yellow);">
          <div class="card-header">
            <span>📄 config.toml</span>
            <div class="card-controls"><span>-</span><span>□</span><span>×</span></div>
          </div>
          <div class="card-body">
            <span class="card-tag">custom</span>
            <h3>30+ themes & custom keys</h3>
            <p class="card-desc">
              Personalize Noodle with over 30 built-in themes (including Catppuccin, Everforest, and Nord) and fully customizable keybindings.
            </p>
            <div class="card-cmd">
              <code>$ noodle --theme catppuccin</code>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Define extra colors specific to Noodle's styling */
  :root {
    --color-orange: #fab387;
    --color-green: #a6e3a1;
    --color-blue: #89b4fa;
    --color-red: #f38ba8;
    --color-purple: #cba6f7;
    --color-yellow: #f9e2af;
  }

  [data-theme="light"],
  .sl-theme-light {
    --color-orange: #fe640b;
    --color-green: #40a02b;
    --color-blue: #1e66f5;
    --color-red: #d20f39;
    --color-purple: #8839ef;
    --color-yellow: #df8e1d;
  }

  .bg-glow {
    position: fixed;
    top: -20%;
    left: -10%;
    width: 120%;
    height: 120%;
    background: radial-gradient(circle at 50% 0%, var(--accent-glow) 0%, rgba(11, 16, 22, 0) 50%);
    pointer-events: none;
    z-index: -1;
  }

  /* ─── TUI Layout ─── */
  .tui-container {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  /* Panels & Cards use retro solid block-shadows instead of soft glows */
  .tui-panel {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 6px 6px 0 var(--border);
    display: flex;
    flex-direction: column;
  }

  .tui-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    background: var(--border);
    font-size: 0.85rem;
    color: var(--fg);
    border-bottom: 1px solid var(--border);
  }
  
  .tui-panel-header .tui-status {
    color: var(--color-green);
  }

  .tui-panel-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Hero Specific */
  .hero-panel h1 {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--fg);
  }
  
  .hero-panel .prompt {
    color: var(--color-green);
    margin-right: 0.5rem;
  }
  
  .blinking-cursor {
    display: inline-block;
    width: 12px;
    background-color: var(--accent);
    animation: blink 1s step-end infinite;
  }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-panel .lede {
    font-size: 1.15rem;
    color: var(--muted);
  }

  /* Installation Pane */
  .install-pane {
    margin-top: 1rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
    overflow: hidden;
    display: flex;
    align-items: stretch;
  }
  
  .install-pane code {
    flex: 1;
    padding: 1rem;
    font-size: 0.9rem;
    overflow-x: auto;
    white-space: nowrap;
    color: var(--color-blue);
  }
  
  .install-pane code::before {
    content: "$ ";
    color: var(--muted);
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.5rem;
    background: var(--border);
    border: none;
    border-left: 1px solid var(--border);
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .copy-btn:hover {
    background: var(--accent);
    color: var(--bg);
  }

  /* Links */
  .secondary-links {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .secondary-links a {
    color: var(--color-purple);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 700;
    transition: color 0.2s;
  }

  .secondary-links a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  /* ─── Features Section ─── */
  .features-section {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    margin-top: 1.5rem;
  }

  .section-header {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 2.5rem;
    align-items: end;
  }

  .section-tag {
    font-size: 0.9rem;
    color: var(--color-purple);
    display: block;
    margin-bottom: 0.5rem;
  }

  .section-header h2 {
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--fg);
    text-align: left;
  }

  .header-right p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--muted);
  }

  /* Cards Grid */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* Window-style TUI Cards with Solid Block-Shadows */
  .tui-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 4px 4px 0 var(--border);
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .tui-card:hover {
    transform: translate(-2px, -2px);
    border-color: var(--accent-color);
    box-shadow: 6px 6px 0 var(--accent-color);
  }

  .card-header {
    background: var(--border);
    padding: 0.4rem 0.75rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    color: var(--fg);
    border-bottom: 1px solid var(--border);
    user-select: none;
  }

  .card-controls {
    display: flex;
    gap: 0.4rem;
    color: var(--muted);
    font-weight: bold;
  }

  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-grow: 1;
  }

  .card-tag {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent-color);
  }

  .tui-card h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--fg);
  }

  .card-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--muted);
    flex-grow: 1;
  }

  .card-cmd {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.6rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg);
  }

  .card-cmd code {
    color: var(--fg);
  }

  /* Responsive Adjustments */
  @media (max-width: 900px) {
    .section-header {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
