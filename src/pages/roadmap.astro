---
import BaseLayout from "../layouts/BaseLayout.astro"

const versions = [
  {
    version: "v0.1.x",
    status: "done",
    title: "Current release",
    features: [
      { text: "Requests in folders (nested request directories)", done: true },
      { text: "Duplicate and delete requests", done: true },
      { text: "Expand panels keybinding (F2 toggle)", done: true },
      { text: "Create requests from UI (Ctrl+N modal)", done: true },
      { text: "Persist UI state (last request + tabs)", done: true },
      { text: "File upload (multipart files + binary body)", done: true },
      { text: "Multipart/form-data body", done: true },
      { text: "Content-Type aware body", done: true },
      { text: "Inline auth editor (None/Bearer/Basic/API Key)", done: true },
      { text: "Max redirects / follow redirects toggle", done: true },
      { text: "Configurable request timeout", done: true },
      { text: "Persistent request history", done: true },
      { text: "Environment editor (CRUD from UI)", done: true },
      { text: "Full-featured CLI mode", done: true },
      { text: "Self-update CLI (noodle update)", done: true },
      { text: "CI/CD", done: true },
      { text: "Packaging: brew, curl, npx", done: true },
      { text: "Website and documentation", done: true },
      { text: "Import from Postman", done: true },
      { text: "Import from OpenAPI 3.x", done: true },
      { text: "Copy JSON body response keybinding", done: true },
      { text: "Empty state on fresh install", done: true },
    ],
    bugs: [
      { text: "URL bar collapses/grows when container is too narrow", done: true },
      { text: "Tabs should scroll horizontally instead of collapsing", done: true },
      { text: "Cannot copy text anywhere in Noodle", done: true },
    ],
    polish: [
      { text: "Recheck the keybindings overlay labels", done: true },
    ],
  },
  {
    version: "v0.2.x",
    status: "done",
    features: [
      { text: "Select a default theme", done: false },
      { text: "Undo all unsaved changes keybinding", done: true },
      { text: "Unified input component for variable interpolation", done: true },
    ],
    bugs: [
      { text: "Show error color when env variable doesn't exist in auth interpolation", done: false },
      { text: "ctrl+e / ctrl+alt+e opens edit overlay on folders when it shouldn't", done: false },
      { text: "Request status lost when switching tabs during active request", done: false },
    ],
  },
  {
    version: "v0.3.x",
    status: "done",
    features: [
      { text: "Collection switcher", done: true },
      { text: "Command palette (Ctrl+P)", done: true },
      { text: "Make theme overlay reusable", done: true },
    ],
  },
  {
    version: "v0.4.x",
    status: "done",
    features: [
      { text: "Working custom JSON/YAML editor", done: true },
      { text: "Autocompletion: Inputs and Body", done: true },
      { text: "Inline error validation", done: true },
    ],
  },
  {
    version: "v0.5.x",
    features: [
      { text: "Search and filter in collections", done: false },
      { text: "JSONPath/jq query for response body", done: false },
      { text: "Generate code from request: cURL, Python, Javascript, etc.", done: false },
      { text: "Import from cURL (paste in URL bar)", done: false },
    ],
  },
  {
    version: "v0.6.x",
    features: [
      { text: "Export collection to OpenAPI/Postman/Insomnia", done: false },
      { text: "Import from Swagger", done: false },
      { text: "Import from Insomnia", done: false },
      { text: "Remember open tabs when switching folders", done: false },
    ],
  },
  {
    version: "v0.7.x",
    features: [
      { text: "Proxy support", done: false },
      { text: "SSL/TLS config", done: false },
      { text: "Cookie jar viewer", done: false },
      { text: "OAuth 2.0", done: false },
    ],
  },
  {
    version: "v0.8.x",
    features: [
      { text: "Pre/post-request scripts in JavaScript", done: false },
    ],
  },
  {
    version: "v0.9.x",
    features: [
      { text: "Custom assertions (status, body, headers, timing)", done: false },
      { text: "Request chaining (set variables across requests)", done: false },
    ],
  },
  {
    version: "v1.0.x",
    status: "goal",
    features: [
      { text: "Collection runner (batch mode, results grid)", done: false },
    ],
  },
]

const doneCount = versions.filter(v => v.status === "done").length
const totalCount = versions.length
---

<BaseLayout title="Roadmap · Noodle" description="Noodle development roadmap and future plans">
  <style is:global>
    /* Color accent overrides */
    :root {
      --color-orange: #fab387;
      --color-green: #a6e3a1;
      --color-blue: #89b4fa;
      --color-red: #f38ba8;
      --color-purple: #cba6f7;
      --color-yellow: #f9e2af;
    }

    [data-theme="light"],
    .sl-theme-light {
      --color-orange: #fe640b;
      --color-green: #40a02b;
      --color-blue: #1e66f5;
      --color-red: #d20f39;
      --color-purple: #8839ef;
      --color-yellow: #df8e1d;
    }

    .roadmap-container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
      position: relative;
      z-index: 2;
    }

    /* ── Header ── */
    .roadmap-header {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 4rem;
      align-items: center;
      margin-bottom: 5rem;
      margin-top: 1rem;
    }

    .roadmap-header-left {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .roadmap-header h1 {
      font-size: clamp(1.6rem, 3.2vw, 2.5rem);
      font-weight: 400;
      line-height: 1.3;
      color: var(--fg);
    }

    .roadmap-header .lede {
      font-size: 1rem;
      line-height: 1.6;
      color: var(--muted);
    }

    .roadmap-header-right {
      display: flex;
      justify-content: center;
      width: 100%;
    }

    .roadmap-stats-window {
      max-width: 100%;
      width: 100%;
    }

    .section-tag {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--color-purple);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      display: block;
    }

    .mock-key {
      color: var(--color-blue);
      font-weight: bold;
    }

    .mock-value {
      color: var(--color-green);
    }

    .mock-line {
      color: var(--fg);
    }

    /* ── Mock Windows ── */
    .mock-code-window {
      width: 100%;
      background: rgba(30, 30, 46, 0.4);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.5rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      line-height: 1.6;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
      backdrop-filter: blur(12px);
      text-align: left;
    }

    .mock-window-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
      border-bottom: 1px dashed var(--border);
      padding-bottom: 0.75rem;
    }

    .mock-file-label {
      color: var(--color-blue);
      font-weight: bold;
    }

    .status-badge {
      font-size: 0.75rem;
      font-weight: 700;
      font-family: var(--font-mono);
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
    }

    .status-badge.done {
      color: var(--color-green);
      border: 1px solid var(--color-green);
    }

    .status-badge.goal {
      color: var(--color-purple);
      border: 1px solid var(--color-purple);
    }

    .status-badge.upcoming {
      color: var(--muted);
      border: 1px solid var(--border);
    }

    /* ── Feed ── */
    .roadmap-feed {
      display: flex;
      flex-direction: column;
      gap: 3rem;
    }

    .roadmap-row {
      display: grid;
      grid-template-columns: 150px 1fr;
      gap: 2.5rem;
    }

    .roadmap-meta {
      position: sticky;
      top: 100px;
      height: fit-content;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      font-family: var(--font-mono);
    }

    .roadmap-meta .version-tag {
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--fg);
      margin: 0;
    }

    .roadmap-meta .version-tag.done {
      color: var(--color-green);
    }

    .roadmap-meta .version-tag.goal {
      color: var(--color-purple);
    }

    .roadmap-meta .meta-status {
      font-size: 0.75rem;
      color: var(--muted);
    }

    /* ── Feature lists inside cards ── */
    .feature-group {
      margin-bottom: 1rem;
    }

    .feature-group:last-child {
      margin-bottom: 0;
    }

    .feature-group-label {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }

    .feature-group-label.features { color: var(--color-blue); }
    .feature-group-label.bugs { color: var(--color-red); }
    .feature-group-label.polish { color: var(--color-purple); }

    .feature-items {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    .feature-items li {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.5;
    }

    .feature-items li.done {
      color: var(--overlay0, #6c7086);
    }

    .feat-icon {
      flex-shrink: 0;
      font-size: 0.75rem;
      min-width: 0.9rem;
    }

    .feat-icon.check { color: var(--color-green); }
    .feat-icon.todo  { color: var(--surface2, #45475a); }
    .feat-icon.bug   { color: var(--color-red); }
    .feat-icon.polish-icon { color: var(--color-purple); }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .roadmap-header {
        grid-template-columns: 1fr;
        gap: 2.5rem;
        margin-top: 0;
        margin-bottom: 4rem;
      }

      .roadmap-header-left {
        align-items: center;
        text-align: center;
      }

      .roadmap-header-right {
        order: 2;
      }

      .roadmap-row {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .roadmap-meta {
        position: static;
        flex-direction: row;
        align-items: baseline;
        gap: 1rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 0.75rem;
      }

      .roadmap-meta .version-tag {
        font-size: 1.25rem;
      }
    }

    /* ── Folding ── */
    .roadmap-details {
      width: 100%;
    }

    .roadmap-details summary {
      list-style: none;
      cursor: pointer;
    }

    .roadmap-details summary::-webkit-details-marker {
      display: none;
    }

    .roadmap-details .mock-window-header {
      cursor: pointer;
      user-select: none;
      border-bottom: none;
      padding-bottom: 0;
      margin-bottom: 0;
    }

    .roadmap-details[open] .mock-window-header {
      border-bottom: 1px dashed var(--border);
      padding-bottom: 0.75rem;
      margin-bottom: 0;
    }

    .roadmap-details .mock-window-header:hover .mock-file-label {
      color: var(--accent);
      transition: color 0.2s;
    }

    .toggle-arrow {
      font-size: 0.6rem;
      color: var(--muted);
      transition: transform 0.2s;
      display: inline-block;
      margin-right: 0.4rem;
    }

    .roadmap-details[open] .toggle-arrow {
      transform: rotate(90deg);
    }

    .roadmap-details-body {
      margin-top: 1.25rem;
    }
  </style>

  <div class="bg-glow"></div>

  <div class="roadmap-container">
    <header class="roadmap-header">
      <div class="roadmap-header-left">
        <span class="section-tag"># product roadmap</span>
        <h1>Roadmap</h1>
        <p class="lede">The path from v0.1 to v1.0 and beyond. Track what's shipped, what's in progress, and what's coming next.</p>
      </div>
      <div class="roadmap-header-right">
        <div class="mock-code-window roadmap-stats-window">
          <div class="mock-window-header">
            <span class="mock-file-label"># system/roadmap_metadata.yml</span>
          </div>
          <div class="mock-line"><span class="mock-key">current_version</span>: <span class="mock-value">v0.4.x</span></div>
          <div class="mock-line"><span class="mock-key">next_milestone</span>: <span class="mock-value">v0.5.x</span></div>
          <div class="mock-line"><span class="mock-key">milestones_done</span>: <span class="mock-value">{doneCount}/{totalCount}</span></div>
          <div class="mock-line"><span class="mock-key">goal</span>: <span class="mock-value">v1.0.x</span></div>
          <div class="mock-line"><span class="mock-key">status</span>: <span class="mock-value">active</span></div>
        </div>
      </div>
    </header>

    <main class="roadmap-feed">
      {versions.map((v) => (
        <div class="roadmap-row">
          <aside class="roadmap-meta">
            <h2 class={`version-tag ${v.status || "upcoming"}`}>{v.version}</h2>
            <span class="meta-status">
              {v.status === "done" ? "released" : v.status === "goal" ? "goal" : "upcoming"}
            </span>
          </aside>
        <div class="roadmap-content">
            <article class="mock-code-window">
              <details class="roadmap-details" open={v.status !== "done"}>
                <summary>
                  <div class="mock-window-header">
                    <span class="mock-file-label">
                      <span class="toggle-arrow">▶</span>
                      # roadmap/{v.version}.md
                    </span>
                    <span class={`status-badge ${v.status || "upcoming"}`}>
                      {v.status === "done" ? "✓ done" : v.status === "goal" ? "◎ goal" : "○ upcoming"}
                    </span>
                  </div>
                </summary>

                <div class="roadmap-details-body">
                  {v.features && (
                    <div class="feature-group">
                      <div class="feature-group-label features">features</div>
                      <ul class="feature-items">
                        {v.features.map((f) => (
                          <li class={f.done ? "done" : ""}>
                            <span class={`feat-icon ${f.done ? "check" : "todo"}`}>{f.done ? "✓" : "○"}</span>
                            {f.text}
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}

                  {v.bugs && (
                    <div class="feature-group">
                      <div class="feature-group-label bugs">bugs</div>
                      <ul class="feature-items">
                        {v.bugs.map((b) => (
                          <li class={b.done ? "done" : ""}>
                            <span class={`feat-icon ${b.done ? "check" : "bug"}`}>{b.done ? "✓" : "●"}</span>
                            {b.text}
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}

                  {v.polish && (
                    <div class="feature-group">
                      <div class="feature-group-label polish">polish</div>
                      <ul class="feature-items">
                        {v.polish.map((p) => (
                          <li class={p.done ? "done" : ""}>
                            <span class={`feat-icon ${p.done ? "check" : "polish-icon"}`}>{p.done ? "✓" : "✦"}</span>
                            {p.text}
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>
              </details>
            </article>
          </div>
        </div>
      ))}
    </main>
  </div>
</BaseLayout>
