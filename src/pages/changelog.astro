---
import BaseLayout from "../layouts/BaseLayout.astro"
import { getCollection, render } from "astro:content"

const entries = await getCollection("changelog")
entries.sort((a, b) => b.data.date.localeCompare(a.data.date) || b.data.tag.localeCompare(a.data.tag))

const rendered = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry)
    return { data: entry.data, Content }
  })
)
---

<BaseLayout title="Changelog · Noodle" description="Release history for noodle">
  <style is:global>
    /* Color accent overrides */
    :root {
      --color-orange: #fab387;
      --color-green: #a6e3a1;
      --color-blue: #89b4fa;
      --color-red: #f38ba8;
      --color-purple: #cba6f7;
      --color-yellow: #f9e2af;
    }

    [data-theme="light"],
    .sl-theme-light {
      --color-orange: #fe640b;
      --color-green: #40a02b;
      --color-blue: #1e66f5;
      --color-red: #d20f39;
      --color-purple: #8839ef;
      --color-yellow: #df8e1d;
    }

    .bg-glow {
      position: fixed;
      top: -20%;
      left: -10%;
      width: 120%;
      height: 120%;
      background: radial-gradient(circle at 50% 0%, var(--accent-glow) 0%, rgba(11, 16, 22, 0) 50%);
      pointer-events: none;
      z-index: -1;
    }

    .changelog-container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
      position: relative;
      z-index: 2;
    }

    .changelog-header {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      margin-bottom: 3.5rem;
    }

    .changelog-header h1 {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 800;
      line-height: 1.2;
      color: var(--fg);
    }

    .changelog-header .lede {
      font-size: 1.1rem;
      line-height: 1.6;
      color: var(--muted);
    }

    .section-tag {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--color-purple);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      display: block;
    }

    /* Install Pill */
    .install-pill {
      display: flex;
      align-items: stretch;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--bg-elevated);
      overflow: hidden;
      max-width: fit-content;
      margin-top: 0.5rem;
    }

    .install-pill code {
      padding: 0.6rem 1rem;
      font-size: 0.85rem;
      white-space: nowrap;
      color: var(--color-blue);
      display: flex;
      align-items: center;
    }

    .install-pill code::before {
      content: "$ ";
      color: var(--muted);
      margin-right: 0.5rem;
    }

    .copy-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 1rem;
      background: var(--border);
      border: none;
      border-left: 1px solid var(--border);
      color: var(--fg);
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
    }

    .copy-btn:hover {
      background: var(--accent);
      color: var(--bg);
    }

    /* Mock Terminal Windows */
    .changelog-feed {
      display: flex;
      flex-direction: column;
      gap: 3.5rem;
    }

    .changelog-row {
      display: grid;
      grid-template-columns: 150px 1fr;
      gap: 2.5rem;
    }

    .changelog-meta {
      position: sticky;
      top: 100px;
      height: fit-content;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      font-family: var(--font-mono);
    }

    .changelog-meta .version-tag {
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--fg);
      margin: 0;
    }

    .changelog-meta .date {
      font-size: 0.85rem;
      color: var(--muted);
    }



    .mock-code-window {
      width: 100%;
      background: rgba(30, 30, 46, 0.4);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.5rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      line-height: 1.6;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
      backdrop-filter: blur(12px);
      text-align: left;
    }

    .mock-window-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
      border-bottom: 1px dashed var(--border);
      padding-bottom: 0.75rem;
    }

    .mock-window-header .tag-link {
      color: var(--color-purple);
      text-decoration: none;
      font-weight: 700;
      font-size: 0.8rem;
      transition: color 0.2s;
    }

    .mock-window-header .tag-link:hover {
      color: var(--accent);
      text-decoration: underline;
    }

    .mock-file-label {
      color: var(--color-blue);
      font-weight: bold;
    }

    /* Scoped Markdown Body Styles */
    .release-body {
      color: var(--muted);
      line-height: 1.7;
    }

    .release-body h2,
    .release-body h3 {
      font-family: var(--font-mono);
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--color-blue);
      margin: 1.5rem 0 0.5rem 0;
    }

    .release-body h2:first-child,
    .release-body h3:first-child {
      margin-top: 0;
    }

    .release-body p {
      margin-bottom: 0.75rem;
    }

    .release-body ul {
      list-style: none;
      padding-left: 0;
      margin: 0.5rem 0 1rem;
    }

    .release-body li {
      position: relative;
      padding-left: 1.25rem;
      margin-bottom: 0.4rem;
    }

    .release-body li::before {
      content: "-";
      position: absolute;
      left: 0;
      top: 0;
      color: var(--color-green);
      font-weight: bold;
    }

    .release-body code {
      background: var(--border);
      padding: 0.1rem 0.4rem;
      border-radius: 3px;
      font-size: 0.78rem;
      color: var(--color-yellow);
      font-family: var(--font-mono);
    }

    .release-body a {
      color: var(--color-blue);
      text-decoration: underline;
    }

    .release-body a:hover {
      color: var(--accent);
    }

    @media (max-width: 600px) {
      .changelog-row {
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }
      .changelog-meta {
        position: static;
        flex-direction: row;
        align-items: baseline;
        gap: 1rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 1rem;
      }
      .changelog-meta .version-tag {
        font-size: 1.25rem;
      }
    }
  </style>

  <div class="bg-glow"></div>

  <div class="changelog-container">
    <header class="changelog-header">
      <span class="section-tag"># release history</span>
      <h1>Changelog</h1>
      <p class="lede">Release history for noodle, the terminal REST client.</p>

      <div class="install-pill">
        <code>noodle update</code>
        <button id="changelog-copy-install-btn" class="copy-btn" onclick="let el = this; navigator.clipboard?.writeText('noodle update'); el.textContent='COPIED'; setTimeout(()=>el.textContent='COPY', 2000);">COPY</button>
      </div>
    </header>

    <main class="changelog-feed">
      {
        rendered.map((r) => (
          <div class="changelog-row">
            <aside class="changelog-meta">
              <h2 class="version-tag">{r.data.tag}</h2>
              <time class="date">{r.data.date}</time>
            </aside>
            <div class="changelog-content">
              <article class="mock-code-window">
                <div class="mock-window-header">
                  <span class="mock-file-label"># changelog/{r.data.tag}.md</span>
                  <a href={r.data.url} class="tag-link" target="_blank" rel="noopener noreferrer">[GitHub Release]</a>
                </div>
                <div class="release-body">
                  <r.Content />
                </div>
              </article>
            </div>
          </div>
        ))
      }
    </main>
  </div>
</BaseLayout>
