---
import BaseLayout from "../layouts/BaseLayout.astro"
import { getCollection, render } from "astro:content"

const entries = await getCollection("changelog")
entries.sort((a, b) => b.data.date.localeCompare(a.data.date))

const rendered = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry)
    return { data: entry.data, Content }
  })
)
---

<BaseLayout title="Changelog · Noodle" description="Release history for noodle">
  <style is:global>
    .changelog-page {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
    }

    .page-title {
      margin-bottom: 3rem;
    }

    .page-title h1 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .page-title p {
      color: var(--muted);
      font-size: 0.8rem;
    }

    .release {
      margin-bottom: 4rem;
    }

    .release:last-child {
      margin-bottom: 0;
    }

    .release-header {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      margin-bottom: 1.5rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--border);
    }

    .release-header .tag {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--accent);
      text-decoration: none;
    }

    .release-header .tag:hover {
      text-decoration: underline;
    }

    .release-header .date {
      color: var(--muted);
      font-size: 0.75rem;
    }

    .release-body {
      color: var(--muted);
      line-height: 1.8;
    }

    .release-body h2,
    .release-body h3 {
      color: var(--fg);
      font-size: 0.9rem;
      font-weight: 600;
      margin: 1.5rem 0 0.75rem;
    }

    .release-body h2:first-child,
    .release-body h3:first-child {
      margin-top: 0;
    }

    .release-body p {
      margin-bottom: 0.75rem;
    }

    .release-body ul {
      margin: 0.5rem 0 1rem;
      padding-left: 1.5rem;
    }

    .release-body li {
      margin-bottom: 0.4rem;
    }

    .release-body code {
      background: var(--border);
      padding: 0.1rem 0.4rem;
      border-radius: 3px;
      font-size: 0.78rem;
      color: #f9e2af;
    }

    .release-body a {
      color: #89b4fa;
      text-decoration: underline;
    }
  </style>

  <div class="changelog-page">
    <div class="page-title">
      <h1>Changelog</h1>
      <p>Release history for noodle</p>
    </div>

    {
      rendered.map((r) => (
        <div class="release">
          <div class="release-header">
            <a href={r.data.url} class="tag" target="_blank">{r.data.tag}</a>
            <span class="date">{r.data.date}</span>
          </div>
          <div class="release-body">
            <r.Content />
          </div>
        </div>
      ))
    }
  </div>
</BaseLayout>
