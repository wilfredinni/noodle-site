---
import BaseLayout from "../layouts/BaseLayout.astro"
import { getCollection, render } from "astro:content"

const entries = await getCollection("changelog")
entries.sort((a, b) => b.data.date.localeCompare(a.data.date) || b.data.tag.localeCompare(a.data.tag))

const rendered = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry)
    return { data: entry.data, Content }
  })
)
---

<BaseLayout title="Changelog · Noodle" description="Release history for noodle">
  <style is:global>
    /* Color accent overrides */
    :root {
      --color-orange: #fab387;
      --color-green: #a6e3a1;
      --color-blue: #89b4fa;
      --color-red: #f38ba8;
      --color-purple: #cba6f7;
      --color-yellow: #f9e2af;
    }

    [data-theme="light"],
    .sl-theme-light {
      --color-orange: #fe640b;
      --color-green: #40a02b;
      --color-blue: #1e66f5;
      --color-red: #d20f39;
      --color-purple: #8839ef;
      --color-yellow: #df8e1d;
    }

    .bg-glow {
      position: fixed;
      top: -20%;
      left: -10%;
      width: 120%;
      height: 120%;
      background: radial-gradient(circle at 50% 0%, var(--accent-glow) 0%, rgba(11, 16, 22, 0) 50%);
      pointer-events: none;
      z-index: -1;
    }

    .changelog-container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
      position: relative;
      z-index: 2;
    }

    .changelog-header {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 4rem;
      align-items: center;
      margin-bottom: 5rem;
      margin-top: 1rem;
    }

    .header-left {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .changelog-header h1 {
      font-size: clamp(1.6rem, 3.2vw, 2.5rem);
      font-weight: 400;
      line-height: 1.3;
      color: var(--fg);
    }

    .changelog-header .lede {
      font-size: 1rem;
      line-height: 1.6;
      color: var(--muted);
    }

    .header-right {
      display: flex;
      justify-content: center;
      width: 100%;
    }

    .release-stats-window {
      max-width: 100%;
      width: 100%;
    }

    .mock-key {
      color: var(--color-blue);
      font-weight: bold;
    }

    .mock-value {
      color: var(--color-green);
    }

    .mock-line {
      color: var(--fg);
    }

    .section-tag {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--color-purple);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      display: block;
    }

    /* Changelog Links */
    .changelog-links {
      display: flex;
      gap: 1.5rem;
      margin-top: 0.5rem;
    }

    .changelog-links a {
      color: var(--color-purple);
      text-decoration: none;
      font-size: 1rem;
      font-weight: 700;
      transition: color 0.2s;
    }

    .changelog-links a:hover {
      color: var(--accent);
      text-decoration: underline;
    }

    /* Mock Terminal Windows */
    .changelog-feed {
      display: flex;
      flex-direction: column;
      gap: 3.5rem;
    }

    .changelog-row {
      display: grid;
      grid-template-columns: 150px 1fr;
      gap: 2.5rem;
    }

    .changelog-meta {
      position: sticky;
      top: 100px;
      height: fit-content;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      font-family: var(--font-mono);
    }

    .changelog-meta .version-tag {
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--fg);
      margin: 0;
    }

    .changelog-meta .date {
      font-size: 0.85rem;
      color: var(--muted);
    }



    .mock-code-window {
      width: 100%;
      background: rgba(30, 30, 46, 0.4);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.5rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      line-height: 1.6;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
      backdrop-filter: blur(12px);
      text-align: left;
    }

    .mock-window-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
      border-bottom: 1px dashed var(--border);
      padding-bottom: 0.75rem;
    }

    .mock-window-header .tag-link {
      color: var(--color-purple);
      text-decoration: none;
      font-weight: 700;
      font-size: 0.8rem;
      transition: color 0.2s;
    }

    .mock-window-header .tag-link:hover {
      color: var(--accent);
      text-decoration: underline;
    }

    .mock-file-label {
      color: var(--color-blue);
      font-weight: bold;
    }

    /* Scoped Markdown Body Styles */
    .release-body {
      color: var(--muted);
      line-height: 1.7;
    }

    .release-body h2,
    .release-body h3 {
      font-family: var(--font-mono);
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--color-blue);
      margin: 1.5rem 0 0.5rem 0;
    }

    .release-body h2:first-child,
    .release-body h3:first-child {
      margin-top: 0;
    }

    .release-body p {
      margin-bottom: 0.75rem;
    }

    .release-body ul {
      list-style: none;
      padding-left: 0;
      margin: 0.5rem 0 1rem;
    }

    .release-body li {
      position: relative;
      padding-left: 1.25rem;
      margin-bottom: 0.4rem;
    }

    .release-body li::before {
      content: "-";
      position: absolute;
      left: 0;
      top: 0;
      color: var(--color-green);
      font-weight: bold;
    }

    .release-body code {
      background: var(--border);
      padding: 0.1rem 0.4rem;
      border-radius: 3px;
      font-size: 0.78rem;
      color: var(--color-yellow);
      font-family: var(--font-mono);
    }

    .release-body a {
      color: var(--color-blue);
      text-decoration: underline;
    }

    .release-body a:hover {
      color: var(--accent);
    }

    @media (max-width: 900px) {
      .changelog-header {
        grid-template-columns: 1fr;
        gap: 2.5rem;
        margin-top: 0;
        margin-bottom: 4rem;
      }

      .header-left {
        align-items: center;
        text-align: center;
      }

      .header-left .changelog-links {
        justify-content: center;
        margin-top: 0.5rem;
      }

      .header-right {
        order: 2;
      }

      .changelog-row {
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }

      .changelog-meta {
        position: static;
        flex-direction: row;
        align-items: baseline;
        gap: 1rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 1rem;
      }

      .changelog-meta .version-tag {
        font-size: 1.25rem;
      }
    }
  </style>

  <div class="bg-glow"></div>

  <div class="changelog-container">
    <header class="changelog-header">
      <div class="header-left">
        <span class="section-tag"># release history</span>
        <h1>Changelog</h1>
        <p class="lede">
            Here you can find the full release history for Noodle, the delicious, free, and open-source terminal REST client
            for your terminal.
        </p>

        <div class="changelog-links">
          <a href="/docs/getting-started/cli/#update">[Update]</a>
          <a href="/roadmap">[Roadmap]</a>
        </div>
      </div>
      <div class="header-right">
        <div class="mock-code-window release-stats-window">
          <div class="mock-window-header">
            <span class="mock-file-label"># system/release_metadata.yml</span>
          </div>
          <div class="mock-line"><span class="mock-key">latest_version</span>: <span class="mock-value">v0.4.1</span></div>
          <div class="mock-line"><span class="mock-key">release_date</span>: <span class="mock-value">2026-07-11</span></div>
          <div class="mock-line"><span class="mock-key">total_releases</span>: <span class="mock-value">9</span></div>
          <div class="mock-line"><span class="mock-key">license</span>: <span class="mock-value">Apache-2.0</span></div>
          <div class="mock-line"><span class="mock-key">status</span>: <span class="mock-value">stable</span></div>
        </div>
      </div>
    </header>

    <main class="changelog-feed">
      {
        rendered.map((r) => (
          <div class="changelog-row">
            <aside class="changelog-meta">
              <h2 class="version-tag">{r.data.tag}</h2>
              <time class="date">{r.data.date}</time>
            </aside>
            <div class="changelog-content">
              <article class="mock-code-window">
                <div class="mock-window-header">
                  <span class="mock-file-label"># changelog/{r.data.tag}.md</span>
                  <a href={r.data.url} class="tag-link" target="_blank" rel="noopener noreferrer">[GitHub Release]</a>
                </div>
                <div class="release-body">
                  <r.Content />
                </div>
              </article>
            </div>
          </div>
        ))
      }
    </main>
  </div>
</BaseLayout>
